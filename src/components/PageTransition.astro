---
// src/components/PageTransition.astro
---

<div
  id="page-transition-overlay"
  transition:persist="page-transition"
  class="fixed inset-0 z-[9999] pointer-events-none select-none overflow-hidden hidden"
>
  <div
    id="swipe-panel"
    class="absolute inset-y-0 w-full bg-[#fafafa] dark:bg-[#030303] shadow-[0_0_50px_rgba(0,0,0,0.15)] dark:shadow-[0_0_50px_rgba(0,0,0,0.5)] flex items-center justify-center"
  >
    <!-- Plane Container -->
    <div
      id="plane-container"
      class="absolute top-1/2 flex items-center justify-center z-10"
    >
      <!-- SVG Airplane -->
      <svg
        viewBox="0 0 24 24"
        class="w-12 h-12 text-[#171717] dark:text-[#fafafa] drop-shadow-[0_2px_8px_rgba(0,0,0,0.15)] dark:drop-shadow-[0_2px_8px_rgba(255,255,255,0.15)] transition-transform duration-300"
        id="airplane-svg"
      >
        <path
          fill="currentColor"
          d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L14 19v-5.5z"
        ></path>
      </svg>
    </div>
  </div>
</div>

<style is:global>
  @keyframes plane-bobbing {
    0%, 100% {
      transform: translate3d(-50%, -55%, 0);
    }
    50% {
      transform: translate3d(-50%, -45%, 0);
    }
  }

  .plane-bob {
    animation: plane-bobbing 1.2s ease-in-out infinite;
  }
</style>

<script>
  declare global {
    interface Window {
      __page_transitions_initialized?: boolean;
    }
  }

  // Script closure to guarantee direction preservation and prevent duplicate triggers
  let transitionDirection = "ltr";
  let isTransitioning = false;

  function onBeforePreparation(e: any) {
    const event = e as any;
    if (isTransitioning) return;
    isTransitioning = true;

    const to = event.to.pathname;

    // Determine transition direction based on destination page
    const isGoingToIndex = to === "/" || to === "/index.html" || to === "";
    const direction = isGoingToIndex ? "rtl" : "ltr";
    transitionDirection = direction;

    const overlay = document.getElementById("page-transition-overlay");
    const panel = document.getElementById("swipe-panel");
    const planeContainer = document.getElementById("plane-container");
    const airplaneSvg = document.getElementById("airplane-svg");

    if (!overlay || !panel || !planeContainer || !airplaneSvg) {
      isTransitioning = false;
      return;
    }

    // Set transition property to none for setup phase
    panel.style.transition = "none";

    // Clean up previous classes and set default layout
    panel.className = "absolute inset-y-0 w-full bg-[#fafafa] dark:bg-[#030303] shadow-[0_0_50px_rgba(0,0,0,0.15)] dark:shadow-[0_0_50px_rgba(0,0,0,0.5)] flex items-center justify-center";
    planeContainer.className = "absolute top-1/2 flex items-center justify-center z-10 plane-bob";

    // Set explicit plane orientation and leading edge position
    if (direction === "ltr") {
      planeContainer.style.left = "100%";
      planeContainer.style.right = "auto";
      airplaneSvg.style.transform = "rotate(90deg)";
      
      // Initial panel transform off-screen left
      panel.style.transform = "translate3d(-100%, 0, 0)";
    } else {
      planeContainer.style.right = "auto";
      planeContainer.style.left = "0%";
      airplaneSvg.style.transform = "rotate(-90deg)";
      
      // Initial panel transform off-screen right
      panel.style.transform = "translate3d(100%, 0, 0)";
    }

    // Show overlay and block clicks
    overlay.classList.remove("hidden");
    overlay.classList.remove("pointer-events-none");
    overlay.classList.add("pointer-events-auto");
    overlay.style.opacity = "1";
    overlay.style.transition = "none";

    // Force layout reflows to paint starting state before transition
    overlay.offsetWidth;
    panel.offsetWidth;

    // Wait 30ms to let Safari/Firefox paint display:block, then apply transition
    setTimeout(() => {
      panel.style.transition = "transform 400ms cubic-bezier(0.25, 1, 0.5, 1)";
      panel.style.transform = "translate3d(0%, 0, 0)";
    }, 30);

    // Serialize page loading: let swipe-in finish first (450ms) so main thread stays idle, then fetch page
    const originalLoader = event.loader;
    event.loader = async function () {
      await new Promise((resolve) => setTimeout(resolve, 450));
      await originalLoader();
    };
  }

  function onBeforeSwap(e: any) {
    if (!isTransitioning) return;
    const event = e as any;
    if (!event.newDocument) return;

    const newOverlay = event.newDocument.getElementById("page-transition-overlay");
    const newPanel = event.newDocument.getElementById("swipe-panel");
    const newPlaneContainer = event.newDocument.getElementById("plane-container");
    const newAirplaneSvg = event.newDocument.getElementById("airplane-svg");

    if (newOverlay && newPanel && newPlaneContainer && newAirplaneSvg) {
      // Ensure overlay is visible in the incoming DOM before it is painted
      newOverlay.classList.remove("hidden");
      newOverlay.classList.remove("pointer-events-none");
      newOverlay.classList.add("pointer-events-auto");
      newOverlay.style.opacity = "1";
      newOverlay.style.transition = "none";

      // Keep panel fully on-screen covering the page swap
      newPanel.style.transition = "none";
      newPanel.style.transform = "translate3d(0%, 0, 0)";

      // Set correct plane state in the new DOM
      if (transitionDirection === "ltr") {
        newPlaneContainer.style.left = "100%";
        newPlaneContainer.style.right = "auto";
        newAirplaneSvg.style.transform = "rotate(90deg)";
      } else {
        newPlaneContainer.style.right = "auto";
        newPlaneContainer.style.left = "0%";
        newAirplaneSvg.style.transform = "rotate(-90deg)";
      }
    }
  }

  function onAfterSwap() {
    if (!isTransitioning) return;

    const overlay = document.getElementById("page-transition-overlay");
    const panel = document.getElementById("swipe-panel");
    const planeContainer = document.getElementById("plane-container");
    const airplaneSvg = document.getElementById("airplane-svg");

    if (!overlay || !panel || !planeContainer || !airplaneSvg) {
      isTransitioning = false;
      return;
    }

    const direction = transitionDirection;

    // Disable transform transitions
    panel.style.transition = "none";

    // Re-apply plane position and rotation based on direction to guarantee state after DOM swap
    if (direction === "ltr") {
      planeContainer.style.left = "100%";
      planeContainer.style.right = "auto";
      airplaneSvg.style.transform = "rotate(90deg)";
    } else {
      planeContainer.style.right = "auto";
      planeContainer.style.left = "0%";
      airplaneSvg.style.transform = "rotate(-90deg)";
    }

    // Explicitly set panel on-screen
    panel.style.transform = "translate3d(0%, 0, 0)";

    // Force layout reflow
    overlay.offsetWidth;
    panel.offsetWidth;

    // Transition the opacity of the overlay to 0 (fade-out reveal)
    overlay.style.transition = "opacity 350ms ease-out";
    overlay.style.opacity = "0";

    // Hide the overlay and restore interaction once transition is done
    setTimeout(() => {
      overlay.classList.add("hidden");
      overlay.classList.add("pointer-events-none");
      overlay.classList.remove("pointer-events-auto");
      overlay.style.opacity = "1"; // reset opacity for next transition
      
      // Reset transition lock
      isTransitioning = false;
    }, 350);
  }

  function initTransitions() {
    // Prevent duplicate registration on the same document object
    if ((document as any).__page_transitions_initialized) return;
    (document as any).__page_transitions_initialized = true;

    // Register event listeners
    document.addEventListener("astro:before-preparation", onBeforePreparation);
    document.addEventListener("astro:before-swap", onBeforeSwap);
    document.addEventListener("astro:after-swap", onAfterSwap);
  }

  // Initialize event listeners
  initTransitions();
</script>
