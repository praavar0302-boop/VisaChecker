---
// src/components/PageTransition.astro
---

<div
  id="page-transition-overlay"
  transition:persist="page-transition"
  class="fixed inset-0 z-[9999] pointer-events-none select-none overflow-hidden hidden"
>
  <div
    id="swipe-panel"
    class="absolute inset-y-0 w-full bg-[#fafafa] dark:bg-[#030303] shadow-[0_0_50px_rgba(0,0,0,0.15)] dark:shadow-[0_0_50px_rgba(0,0,0,0.5)] flex items-center justify-center"
  >
    <!-- Plane Container -->
    <div
      id="plane-container"
      class="absolute top-1/2 flex items-center justify-center z-10"
    >
      <!-- SVG Airplane -->
      <svg
        viewBox="0 0 24 24"
        class="w-12 h-12 text-[#171717] dark:text-[#fafafa] drop-shadow-[0_2px_8px_rgba(0,0,0,0.15)] dark:drop-shadow-[0_2px_8px_rgba(255,255,255,0.15)] transition-transform duration-300"
        id="airplane-svg"
      >
        <path
          fill="currentColor"
          d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L14 19v-5.5z"
        ></path>
      </svg>
    </div>
  </div>
</div>

<style is:global>
  /* Define keyframe animations for swipe transition */
  @keyframes swipe-in-left-to-right {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(0%);
    }
  }

  @keyframes swipe-out-left-to-right {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(100%);
    }
  }

  @keyframes swipe-in-right-to-left {
    0% {
      transform: translateX(100%);
    }
    100% {
      transform: translateX(0%);
    }
  }

  @keyframes swipe-out-right-to-left {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  @keyframes plane-bobbing {
    0%, 100% {
      transform: translate(-50%, -55%);
    }
    50% {
      transform: translate(-50%, -45%);
    }
  }

  /* Classes to trigger animations */
  .animate-swipe-in-ltr {
    animation: swipe-in-left-to-right 650ms cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  .animate-swipe-out-ltr {
    animation: swipe-out-left-to-right 650ms cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  .animate-swipe-in-rtl {
    animation: swipe-in-right-to-left 650ms cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  .animate-swipe-out-rtl {
    animation: swipe-out-right-to-left 650ms cubic-bezier(0.76, 0, 0.24, 1) forwards;
  }

  .plane-bob {
    animation: plane-bobbing 1.2s ease-in-out infinite;
  }
</style>

<script>
  function initTransitions() {
    document.addEventListener("astro:before-preparation", (event) => {
      const to = event.to.pathname;

      // Determine transition direction based on destination page
      const isGoingToIndex = to === "/" || to === "/index.html" || to === "";
      const direction = isGoingToIndex ? "rtl" : "ltr";

      const overlay = document.getElementById("page-transition-overlay");
      const panel = document.getElementById("swipe-panel");
      const planeContainer = document.getElementById("plane-container");
      const airplaneSvg = document.getElementById("airplane-svg");

      if (!overlay || !panel || !planeContainer || !airplaneSvg) return;

      // Save direction for after-swap phase
      panel.setAttribute("data-direction", direction);

      // Clean up previous classes
      panel.className = "absolute inset-y-0 w-full bg-[#fafafa] dark:bg-[#030303] shadow-[0_0_50px_rgba(0,0,0,0.15)] dark:shadow-[0_0_50px_rgba(0,0,0,0.5)] flex items-center justify-center";
      planeContainer.className = "absolute top-1/2 flex items-center justify-center z-10 plane-bob";

      if (direction === "ltr") {
        // Position plane on the right (leading edge)
        planeContainer.style.left = "100%";
        planeContainer.style.right = "auto";
        
        // Face right
        airplaneSvg.style.transform = "rotate(90deg)";
      } else {
        // Position plane on the left (leading edge)
        planeContainer.style.right = "auto";
        planeContainer.style.left = "0%";
        
        // Face left
        airplaneSvg.style.transform = "rotate(-90deg)";
      }

      // Show overlay and block clicks
      overlay.classList.remove("hidden");
      overlay.classList.remove("pointer-events-none");
      overlay.classList.add("pointer-events-auto");

      // Apply the swipe in animation class
      if (direction === "ltr") {
        panel.classList.add("animate-swipe-in-ltr");
      } else {
        panel.classList.add("animate-swipe-in-rtl");
      }

      // Delay page loading until screen is fully covered (650ms)
      const originalLoader = event.loader;
      event.loader = async function () {
        await new Promise((resolve) => setTimeout(resolve, 650));
        await originalLoader();
      };
    });

    document.addEventListener("astro:after-swap", () => {
      const overlay = document.getElementById("page-transition-overlay");
      const panel = document.getElementById("swipe-panel");

      if (!overlay || !panel) return;

      const direction = panel.getAttribute("data-direction");

      // Remove the swipe-in animation class
      panel.classList.remove("animate-swipe-in-ltr", "animate-swipe-in-rtl");

      // Trigger the swipe-out animation
      if (direction === "ltr") {
        panel.classList.add("animate-swipe-out-ltr");
      } else {
        panel.classList.add("animate-swipe-out-rtl");
      }

      // Hide the overlay and restore interaction once transition is done
      setTimeout(() => {
        // Only hide if we are in the finished state
        if (
          panel.classList.contains("animate-swipe-out-ltr") ||
          panel.classList.contains("animate-swipe-out-rtl")
        ) {
          overlay.classList.add("hidden");
          overlay.classList.add("pointer-events-none");
          overlay.classList.remove("pointer-events-auto");
          
          // Clean classes
          panel.classList.remove("animate-swipe-out-ltr", "animate-swipe-out-rtl");
        }
      }, 650);
    });
  }

  // Initialize event listeners
  initTransitions();
</script>
