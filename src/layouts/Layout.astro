---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import PageTransition from '../components/PageTransition.astro';
import Header from '../components/Header.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Can I Fly There? | Instant Visa Requirement Checker",
	description = "Instant visa requirement checker for international travelers. Verify bilateral visa rules, stay limits, and visa on arrival eligibility for 197+ countries instantly."
} = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-QDGEY3CY24" is:inline></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-QDGEY3CY24');
		</script>

		<!-- Google AdSense -->
		<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6523425301296238" crossorigin="anonymous" is:inline></script>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="CIFD" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Theme Sync Script to prevent FOUC -->
		<script is:inline>
			(function() {
				const theme = (() => {
					if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
						return localStorage.getItem('theme');
					}
					return 'dark';
				})();
				
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			})();
		</script>

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={Astro.url.href} />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- OpenGraph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:image" content={new URL('/favicon-96x96.png', Astro.url).href} />
		<meta property="og:site_name" content="Global Visa Tracker" />

		<!-- Twitter Card Meta Tags -->
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL('/favicon-96x96.png', Astro.url).href} />

		{Astro.url.pathname === '/' && (
			<script type="application/ld+json" is:inline set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "Global Visa Tracker",
				"url": Astro.url.origin,
				"potentialAction": {
					"@type": "SearchAction",
					"target": `${Astro.url.origin}/visas?q={search_term_string}`,
					"query-input": "required name=search_term_string"
				}
			})} />
		)}
		
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono&display=swap" rel="stylesheet" />
		
		<ClientRouter />
	</head>
	<body class="bg-[#fafafa] text-[#171717] dark:bg-[#030303] dark:text-[#fafafa] antialiased selection:bg-zinc-900 selection:text-white dark:selection:bg-[#fafafa] dark:selection:text-[#030303]">
		<Header />
		<div class="relative overflow-x-hidden min-h-screen w-full flex flex-col justify-between">
			<slot />
		</div>
		<PageTransition />
		<script>
			function applyTheme() {
				const theme = (() => {
					if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
						return localStorage.getItem('theme');
					}
					return 'dark';
				})();
				
				if (theme === 'dark') {
					document.documentElement.classList.add('dark');
				} else {
					document.documentElement.classList.remove('dark');
				}
			}

			document.addEventListener("astro:after-swap", applyTheme);

			document.addEventListener("astro:page-load", () => {
				applyTheme();
				const themeToggleBtn = document.getElementById("theme-toggle");
				if (themeToggleBtn) {
					themeToggleBtn.addEventListener("click", () => {
						const isDark = document.documentElement.classList.contains("dark");
						if (isDark) {
							document.documentElement.classList.remove("dark");
							localStorage.setItem("theme", "light");
						} else {
							document.documentElement.classList.add("dark");
							localStorage.setItem("theme", "dark");
						}
					});
				}
			});
		</script>
	</body>
</html>
