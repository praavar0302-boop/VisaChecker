---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout 
  title="Contact Global Visa Tracker Support | Open-Source Feedback"
  description="Get in touch with the Global Visa Tracker contributors. Report database mismatches, submit suggestions, or inquire about data partnerships."
>
  <!-- Background Glow FX -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-gradient-to-tr from-[#007cf0]/10 via-[#7928ca]/10 to-[#ff0080]/5 blur-[130px] pointer-events-none"></div>
  <div class="absolute bottom-10 right-1/4 w-[500px] h-[500px] rounded-full bg-gradient-to-br from-[#00dfd8]/5 via-[#f9cb28]/5 to-emerald-500/5 blur-[120px] pointer-events-none"></div>

  <!-- Content Section -->
  <main class="max-w-3xl mx-auto px-4 py-16 relative">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 font-mono text-[9px] text-zinc-500 uppercase tracking-widest mb-6">
      <a href="/" class="hover:text-zinc-950 dark:hover:text-white transition-colors">Home</a>
      <span>/</span>
      <span class="text-zinc-400">Contact</span>
    </nav>

    <article class="space-y-8 text-zinc-600 dark:text-zinc-400">
      <div class="space-y-4">
        <span class="font-mono text-[10px] text-zinc-500 uppercase tracking-widest block">
          Contact Us
        </span>
        <h1 class="font-sans text-3xl font-semibold text-zinc-950 dark:text-white tracking-tight transition-colors">
          Get in Touch
        </h1>
        <p class="font-sans text-sm leading-relaxed">
          Have feedback or suggestions to improve our visa database parameters? Send us a message and our team will get back to you shortly.
        </p>
      </div>

      <hr class="border-zinc-200 dark:border-zinc-900" />

      <!-- Contact Form -->
      <form class="space-y-5" onsubmit="event.preventDefault(); alert('Message sent!');">
        <div class="space-y-2">
          <label for="name" class="block font-mono text-[11px] text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">Your Name</label>
          <input type="text" id="name" required class="w-full bg-zinc-55 text-zinc-950 border border-zinc-200 rounded px-3 py-3 font-sans text-sm focus:outline-none focus:border-zinc-400 dark:bg-[#0d0d0d] dark:text-white dark:border-zinc-800 dark:focus:border-zinc-500 transition-colors" />
        </div>
        <div class="space-y-2">
          <label for="email" class="block font-mono text-[11px] text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">Email Address</label>
          <input type="email" id="email" required class="w-full bg-zinc-55 text-zinc-950 border border-zinc-200 rounded px-3 py-3 font-sans text-sm focus:outline-none focus:border-zinc-400 dark:bg-[#0d0d0d] dark:text-white dark:border-zinc-800 dark:focus:border-zinc-500 transition-colors" />
        </div>
        <div class="space-y-2">
          <label for="message" class="block font-mono text-[11px] text-zinc-500 dark:text-zinc-400 uppercase tracking-wider">Message Description</label>
          <textarea id="message" rows="5" required class="w-full bg-zinc-55 text-zinc-950 border border-zinc-200 rounded px-3 py-3 font-sans text-sm focus:outline-none focus:border-zinc-400 dark:bg-[#0d0d0d] dark:text-white dark:border-zinc-800 dark:focus:border-zinc-500 transition-colors"></textarea>
        </div>
        <button type="submit" class="w-full bg-zinc-950 text-white dark:bg-white dark:text-black py-3 rounded font-sans font-medium text-sm hover:opacity-90 transition-opacity cursor-pointer">
          Send Message
        </button>
      </form>
    </article>
  </main>

  <!-- Reusable Footer -->
  <Footer />


</Layout>
