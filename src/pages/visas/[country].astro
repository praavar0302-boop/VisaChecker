---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import visaDataMatrix from "../../data/passport-index.json";
import officialPortals from "../../data/official-portals.json";

export async function getStaticPaths() {
  const regionNames = new Intl.DisplayNames(["en"], { type: "region" });
  return Object.keys(visaDataMatrix).map((code) => {
    let name = code;
    try {
      name = regionNames.of(code) || code;
    } catch (e) {}
    return {
      params: { country: code.toLowerCase() },
      props: { code, name },
    };
  });
}

const { code, name } = Astro.props;
const rules = (visaDataMatrix as any)[code] || {};

// Convert ISO-2 country code to flag emoji
function getFlagEmoji(countryCode: string) {
  if (!countryCode || countryCode.length !== 2) return "🏳️";
  const codePoints = countryCode
    .toUpperCase()
    .split("")
    .map((char) => 127397 + char.charCodeAt(0));
  try {
    return String.fromCodePoint(...codePoints);
  } catch (e) {
    return "🏳️";
  }
}

const regionNames = new Intl.DisplayNames(["en"], { type: "region" });

function getCountryName(cCode: string) {
  try {
    return regionNames.of(cCode) || cCode;
  } catch (e) {
    return cCode;
  }
}

const destinations = Object.keys(visaDataMatrix)
  .map((destCode) => {
    if (destCode === code) return null;
    const rule = rules[destCode] || { status: "visa required" };
    const status = rule.status ? rule.status.toLowerCase() : "";
    const days = rule.days ? parseInt(rule.days) : null;

    let friendlyStatus = "Visa Required";
    let category = "required"; // "free", "evisa", "voa", "required"

    if (status === "visa free" || !isNaN(Number(status))) {
      friendlyStatus = "Visa-Free";
      category = "free";
    } else if (status === "eta") {
      friendlyStatus = "eTA";
      category = "eta";
    } else if (status === "visa on arrival") {
      friendlyStatus = "Visa on Arrival";
      category = "voa";
    }

    return {
      code: destCode,
      name: getCountryName(destCode),
      status: friendlyStatus,
      category,
      days: rule.days || null,
      flag: getFlagEmoji(destCode),
      portal: (officialPortals as any)[destCode] || null,
    };
  })
  .filter(Boolean)
  .sort((a: any, b: any) => a.name.localeCompare(b.name));

const freeCount = destinations.filter((d: any) => d.category === "free").length;
const etaCount = destinations.filter((d: any) => d.category === "eta").length;
const voaCount = destinations.filter((d: any) => d.category === "voa").length;
const requiredCount = destinations.filter((d: any) => d.category === "required").length;
const mobilityScore = freeCount + voaCount + etaCount;

// Calculate ranking
const rawRankings = Object.keys(visaDataMatrix)
  .map((cCode) => {
    const cRules = (visaDataMatrix as any)[cCode] || {};
    const score = Object.values(cRules).filter((r: any) => {
      const s = r.status ? r.status.toLowerCase() : "";
      return s === "visa free" || !isNaN(Number(s)) || s === "eta" || s === "visa on arrival";
    }).length;
    return { code: cCode, score };
  })
  .sort((a, b) => b.score - a.score);

let currentRank = 0;
let prevScore = -1;
const rankings = rawRankings.map((r) => {
  if (r.score !== prevScore) {
    currentRank++;
    prevScore = r.score;
  }
  return { ...r, rank: currentRank };
});

const myRankObj = rankings.find((r) => r.code === code);
const globalRank = myRankObj ? myRankObj.rank : 1;

// Generate Dynamic FAQs for popular countries
const popularTargets = ["US", "GB", "JP", "AU", "DE", "FR", "IN"];
const faqs = popularTargets
  .map((tCode) => {
    if (tCode === code) return null;
    const destName = getCountryName(tCode);
    const rule = rules[tCode] || { status: "visa required" };
    const status = rule.status ? rule.status.toLowerCase() : "";
    const days = rule.days ? parseInt(rule.days) : 0;

    let text = "";
    if (status === "visa free" || !isNaN(Number(status))) {
      text = `${destName} is **Visa-Free** for ${name} citizens. You can stay for up to ${rule.days || "90"} days without acquiring a visa prior to travel.`;
    } else if (status === "eta") {
      text = `An **eTA** is required for ${name} citizens visiting ${destName}. You can easily apply online before your departure date. ${rule.days ? `The stay limit is generally ${rule.days} days.` : ""}`;
    } else if (status === "visa on arrival") {
      text = `${name} passport holders can obtain a **Visa on Arrival** upon landing at the border checkpoints in ${destName}. ${rule.days ? `This permits stays up to ${rule.days} days.` : ""}`;
    } else {
      text = `Yes, a **traditional consular/embassy visa** is required for ${name} citizens traveling to ${destName}. You must submit a physical application, passport, and supporting documents at the nearest consulate or visa application center.`;
    }

    return {
      question: `Do ${name} citizens need a visa to travel to ${destName}?`,
      answer: text,
    };
  })
  .filter(Boolean);

// Create JSON-LD FAQ Schema
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq: any) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer.replace(/\*\*/g, ""), // clean markdown bold markers
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": Astro.url.origin
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Passport Directory",
      "item": `${Astro.url.origin}/visas`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": `${name} Visa Guide`,
      "item": Astro.url.href
    }
  ]
};

const flagEmoji = getFlagEmoji(code);
---

<Layout 
  title={`${name} Passport Visa Requirements 2026 | Visa-Free Countries`}
  description={`Comprehensive travel guide for ${name} passport holders. Discover the list of ${freeCount} visa-free, ${etaCount} eTA, and ${voaCount} visa on arrival destinations for ${name} citizens.`}
>
  <!-- Background Glow FX -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-gradient-to-tr from-[#007cf0]/10 via-[#7928ca]/10 to-[#ff0080]/5 blur-[130px] pointer-events-none"></div>
  <div class="absolute bottom-10 right-1/4 w-[500px] h-[500px] rounded-full bg-gradient-to-br from-[#00dfd8]/5 via-[#f9cb28]/5 to-emerald-500/5 blur-[120px] pointer-events-none"></div>

  <main class="max-w-5xl mx-auto px-4 pt-12 pb-24 relative">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 font-mono text-[9px] text-zinc-500 uppercase tracking-widest mb-6">
      <a href="/" class="hover:text-zinc-950 dark:hover:text-white transition-colors">Home</a>
      <span>/</span>
      <a href="/visas" class="hover:text-zinc-950 dark:hover:text-white transition-colors">Passports</a>
      <span>/</span>
      <span class="text-zinc-900 dark:text-zinc-200">{name}</span>
    </nav>

    <!-- Header Block -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 pb-8 border-b border-zinc-200 dark:border-zinc-900/50">
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <span class="text-4xl select-none" role="img" aria-label={name}>{flagEmoji}</span>
          <h1 class="font-sans text-3xl md:text-4xl font-semibold tracking-tight text-zinc-950 dark:text-white leading-tight">
            {name} Passport Visa Requirements.
          </h1>
        </div>
        <p class="font-sans text-xs text-zinc-500 dark:text-zinc-300 leading-relaxed max-w-xl">
          Comprehensive guide detailing the travel accessibility, visa waivers, and entry limits for passport holders of <strong>{name}</strong> in 2026.
        </p>
      </div>
      <div class="flex items-center gap-3 font-mono text-[10px]">
        <div class="px-3 py-1.5 rounded bg-zinc-100 border border-zinc-200 dark:bg-zinc-950 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 tracking-wider uppercase">
          Mobility Score: <span class="text-zinc-950 dark:text-white font-bold">{mobilityScore}</span>
        </div>
        <div class="px-3 py-1.5 rounded bg-zinc-100 border border-zinc-200 dark:bg-zinc-950 dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 tracking-wider uppercase">
          Global Rank: <span class="text-zinc-950 dark:text-white font-bold">#{globalRank}</span>
        </div>
      </div>
    </div>

    <!-- Mobility Dashboard Grid -->
    <section class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-10">
      <div class="p-5 rounded-lg border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-[#080808] transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.02)]">
        <span class="font-mono text-[9px] text-zinc-500 uppercase tracking-widest">Mobility Score</span>
        <span class="block font-mono text-3xl font-semibold text-zinc-950 dark:text-white mt-1">{mobilityScore}</span>
        <p class="font-sans text-[10px] text-zinc-400 mt-2">Total visa-free or eVisa access destinations.</p>
      </div>
      <div class="p-5 rounded-lg border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-[#080808] transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.02)]">
        <span class="font-mono text-[9px] text-zinc-500 uppercase tracking-widest text-emerald-600 dark:text-emerald-450">Visa-Free</span>
        <span class="block font-mono text-3xl font-semibold text-emerald-600 dark:text-emerald-400 mt-1">{freeCount}</span>
        <p class="font-sans text-[10px] text-zinc-400 mt-2">Destinations permitting entry without pre-clearing.</p>
      </div>
      <div class="p-5 rounded-lg border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-[#080808] transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.02)]">
        <span class="font-mono text-[9px] text-zinc-500 uppercase tracking-widest text-blue-600 dark:text-blue-450">eTA</span>
        <span class="block font-mono text-3xl font-semibold text-blue-600 dark:text-blue-400 mt-1">{etaCount}</span>
        <p class="font-sans text-[10px] text-zinc-400 mt-2">Electronic travel authorization applied for online before flight.</p>
      </div>
      <div class="p-5 rounded-lg border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-[#080808] transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.02)]">
        <span class="font-mono text-[9px] text-zinc-500 uppercase tracking-widest text-teal-600 dark:text-teal-450">Visa on Arrival</span>
        <span class="block font-mono text-3xl font-semibold text-teal-600 dark:text-teal-400 mt-1">{voaCount}</span>
        <p class="font-sans text-[10px] text-zinc-400 mt-2">Permits issued instantly upon landing at borders.</p>
      </div>
      <div class="col-span-2 lg:col-span-1 p-5 rounded-lg border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-[#080808] transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.02)]">
        <span class="font-mono text-[9px] text-zinc-500 uppercase tracking-widest text-red-600 dark:text-red-400">Visa Required</span>
        <span class="block font-mono text-3xl font-semibold text-red-600 dark:text-red-400 mt-1">{requiredCount}</span>
        <p class="font-sans text-[10px] text-zinc-400 mt-2">Requires traditional consular passport stamping.</p>
      </div>
    </section>

    <!-- Search and Category Filters -->
    <div class="flex flex-col md:flex-row gap-4 justify-between items-start md:items-center mb-6">
      <div class="relative w-full md:w-80">
        <span class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-4 w-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </span>
        <input
          type="text"
          id="dest-search"
          placeholder="Filter destinations..."
          class="w-full bg-white text-zinc-950 border border-zinc-200 rounded-lg pl-9 pr-4 py-2 font-sans text-xs focus:outline-none focus:border-zinc-400 focus:ring-1 focus:ring-zinc-400 dark:bg-[#080808] dark:text-white dark:border-zinc-800 dark:focus:border-zinc-600 transition-colors shadow-[0_1px_2px_rgba(0,0,0,0.02)]"
        />
      </div>

      <div class="flex flex-wrap gap-1.5 font-mono text-[9px] uppercase tracking-wider">
        <button data-filter="all" class="filter-btn px-2.5 py-1.5 rounded border border-zinc-300 dark:border-zinc-800 bg-zinc-950 text-white dark:bg-white dark:text-black font-semibold cursor-pointer select-none">
          All ({destinations.length})
        </button>
        <button data-filter="free" class="filter-btn px-2.5 py-1.5 rounded border border-zinc-200 dark:border-zinc-800 hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors cursor-pointer select-none text-zinc-500 dark:text-zinc-400">
          Visa-Free ({freeCount})
        </button>
        <button data-filter="eta" class="filter-btn px-2.5 py-1.5 rounded border border-zinc-200 dark:border-zinc-800 hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors cursor-pointer select-none text-zinc-500 dark:text-zinc-400">
          eTA ({etaCount})
        </button>
        <button data-filter="voa" class="filter-btn px-2.5 py-1.5 rounded border border-zinc-200 dark:border-zinc-800 hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors cursor-pointer select-none text-zinc-500 dark:text-zinc-400">
          On Arrival ({voaCount})
        </button>
        <button data-filter="required" class="filter-btn px-2.5 py-1.5 rounded border border-zinc-200 dark:border-zinc-800 hover:bg-zinc-100 dark:hover:bg-zinc-900 transition-colors cursor-pointer select-none text-zinc-500 dark:text-zinc-400">
          Required ({requiredCount})
        </button>
      </div>
    </div>

    <!-- Desktop/Tablet View: Table (hidden on mobile, visible on md and up) -->
    <div id="desktop-table-wrapper" class="hidden md:block overflow-x-auto border border-zinc-200 dark:border-zinc-900 bg-white dark:bg-[#060606] rounded-lg shadow-[0_1px_2px_rgba(0,0,0,0.02)] mb-10 transition-colors">
      <table class="w-full border-collapse text-left text-xs font-sans">
        <thead class="bg-zinc-50 dark:bg-zinc-950 font-mono text-[9px] uppercase tracking-wider text-zinc-500 dark:text-zinc-550 border-b border-zinc-200 dark:border-zinc-900 transition-colors">
          <tr>
            <th class="px-5 py-3.5 font-medium">Destination</th>
            <th class="px-5 py-3.5 font-medium">Clearance Category</th>
            <th class="px-5 py-3.5 font-medium">Allowed stay limit</th>
            <th class="px-5 py-3.5 font-medium text-right">Official Application link</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100 dark:divide-zinc-900" id="destinations-tbody">
          {destinations.map((d: any) => (
            <tr 
              class="dest-row hover:bg-zinc-50/40 dark:hover:bg-zinc-950/20 transition-colors"
              data-dest-name={d.name.toLowerCase()}
              data-dest-code={d.code}
              data-dest-category={d.category}
            >
              <td class="px-5 py-3.5 flex items-center gap-3 min-w-0 font-medium text-zinc-950 dark:text-zinc-100">
                <span class="text-xl select-none" role="img" aria-label={d.name}>{d.flag}</span>
                <span class="truncate">{d.name} <span class="font-mono text-[10px] text-zinc-400 font-normal">({d.code})</span></span>
              </td>
              <td class="px-5 py-3.5">
                {d.category === "free" && (
                  <span class="px-2 py-0.5 rounded-full font-mono text-[9px] bg-emerald-50 text-emerald-700 dark:bg-emerald-950/20 dark:text-emerald-400 border border-emerald-250 dark:border-emerald-900/30 uppercase font-semibold">
                    Visa-Free
                  </span>
                )}
                {d.category === "eta" && (
                  <span class="px-2 py-0.5 rounded-full font-mono text-[9px] bg-blue-50 text-blue-700 dark:bg-blue-950/20 dark:text-blue-400 border border-blue-250 dark:border-blue-900/30 uppercase font-semibold">
                    eTA
                  </span>
                )}
                {d.category === "voa" && (
                  <span class="px-2 py-0.5 rounded-full font-mono text-[9px] bg-teal-50 text-teal-700 dark:bg-teal-950/20 dark:text-teal-450 border border-teal-250 dark:border-teal-900/30 uppercase font-semibold">
                    On Arrival
                  </span>
                )}
                {d.category === "required" && (
                  <span class="px-2 py-0.5 rounded-full font-mono text-[9px] bg-zinc-100 text-zinc-700 dark:bg-zinc-950 dark:text-zinc-400 border border-zinc-200 dark:border-zinc-800 uppercase font-semibold">
                    Visa Required
                  </span>
                )}
              </td>
              <td class="px-5 py-3.5 font-mono text-[11px] text-zinc-700 dark:text-zinc-350">
                {d.days ? `${d.days} days` : "—"}
              </td>
              <td class="px-5 py-3.5 text-right whitespace-nowrap">
                {d.portal ? (
                  <a
                    href={d.portal}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center font-mono text-[10px] text-zinc-500 hover:text-zinc-950 dark:text-zinc-400 dark:hover:text-white border border-zinc-200 dark:border-zinc-800 rounded px-2.5 py-1 bg-white dark:bg-[#0c0c0c] hover:border-zinc-300 dark:hover:border-zinc-700 transition-colors uppercase tracking-wider group"
                  >
                    <span>Apply / Info</span>
                    <svg class="w-3 h-3 ml-1 transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                ) : (
                  <span class="font-mono text-[10px] text-zinc-400">—</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Mobile View: Card List (hidden on tablet/desktop, visible on mobile) -->
    <div id="mobile-cards-wrapper" class="block md:hidden space-y-3 mb-10">
      {destinations.map((d: any) => (
        <div 
          class="dest-card p-4 rounded-lg border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-[#080808] flex flex-col gap-3 shadow-[0_1px_2px_rgba(0,0,0,0.02)] transition-colors"
          data-dest-name={d.name.toLowerCase()}
          data-dest-code={d.code}
          data-dest-category={d.category}
        >
          <div class="flex items-center justify-between gap-2">
            <div class="flex items-center gap-3 min-w-0 font-medium text-zinc-950 dark:text-zinc-100 text-xs">
              <span class="text-xl select-none" role="img" aria-label={d.name}>{d.flag}</span>
              <span class="truncate">{d.name} <span class="font-mono text-[9px] text-zinc-400 font-normal">({d.code})</span></span>
            </div>
            <div class="flex-shrink-0">
              {d.category === "free" && (
                <span class="px-2 py-0.5 rounded-full font-mono text-[9px] bg-emerald-50 text-emerald-700 dark:bg-emerald-950/20 dark:text-emerald-400 border border-emerald-250 dark:border-emerald-900/30 uppercase font-semibold">
                  Visa-Free
                </span>
              )}
              {d.category === "eta" && (
                <span class="px-2 py-0.5 rounded-full font-mono text-[9px] bg-blue-50 text-blue-700 dark:bg-blue-950/20 dark:text-blue-400 border border-blue-250 dark:border-blue-900/30 uppercase font-semibold">
                  eTA
                </span>
              )}
              {d.category === "voa" && (
                <span class="px-2 py-0.5 rounded-full font-mono text-[9px] bg-teal-50 text-teal-700 dark:bg-teal-950/20 dark:text-teal-450 border border-teal-250 dark:border-teal-900/30 uppercase font-semibold">
                  On Arrival
                </span>
              )}
              {d.category === "required" && (
                <span class="px-2 py-0.5 rounded-full font-mono text-[9px] bg-zinc-100 text-zinc-700 dark:bg-zinc-950 dark:text-zinc-400 border border-zinc-200 dark:border-zinc-800 uppercase font-semibold">
                  Required
                </span>
              )}
            </div>
          </div>
          <div class="flex items-center justify-between border-t border-zinc-100 dark:border-zinc-900 pt-3 text-[11px]">
            <span class="font-mono text-[9px] text-zinc-500 uppercase tracking-wider">Stay Limit:</span>
            <span class="font-mono font-semibold text-zinc-800 dark:text-zinc-350">{d.days ? `${d.days} days` : "—"}</span>
          </div>
          {d.portal && (
            <a
              href={d.portal}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full flex items-center justify-center gap-1.5 font-mono text-[9px] text-zinc-500 hover:text-zinc-950 dark:text-zinc-400 dark:hover:text-white border border-zinc-200 dark:border-zinc-800 rounded py-2 bg-zinc-50 dark:bg-[#0c0c0c] hover:border-zinc-300 dark:hover:border-zinc-700 transition-colors uppercase tracking-wider group"
            >
              <span>Apply / Info</span>
              <svg class="w-3 h-3 ml-1 transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
      ))}
    </div>

    <!-- Empty State -->
    <div id="no-dest-results" class="hidden text-center py-16 border border-dashed border-zinc-200 dark:border-zinc-800 rounded-lg mb-10">
      <svg class="mx-auto h-8 w-8 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <h3 class="mt-4 text-sm font-sans font-medium text-zinc-900 dark:text-zinc-100">No destinations found</h3>
      <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-350">Try adjusting your search keywords or filter category.</p>
    </div>

    <!-- Informational FAQ and Travel Guides -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start mt-20 border-t border-zinc-200 dark:border-zinc-900/50 pt-12">
      <!-- Left side: FAQs (7 cols) -->
      <section class="lg:col-span-7 space-y-6">
        <h2 class="font-sans text-lg font-semibold text-zinc-950 dark:text-white transition-colors">
          Frequently asked questions ({name} passport).
        </h2>
        <div class="space-y-4">
          {faqs.map((faq: any, idx) => (
            <details class="group border border-zinc-200 dark:border-zinc-800 rounded-lg bg-white dark:bg-[#080808] transition-colors duration-300">
              <summary class="flex justify-between items-center font-sans text-xs font-semibold text-zinc-900 dark:text-zinc-100 px-5 py-4 cursor-pointer list-none select-none">
                <span>{faq.question}</span>
                <span class="transition-transform duration-300 group-open:rotate-180 text-zinc-500">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </span>
              </summary>
              <div class="px-5 pb-5 font-sans text-xs text-zinc-600 dark:text-zinc-300 leading-relaxed border-t border-zinc-100 dark:border-zinc-900/50 pt-4">
                <p set:html={faq.answer.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")} />
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- Right side: Travel Guide/Checklist (5 cols) -->
      <section class="lg:col-span-5 space-y-6">
        <div class="p-6 rounded-lg border border-zinc-200 bg-white dark:border-zinc-900 dark:bg-[#080808] shadow-[0_1px_2px_rgba(0,0,0,0.02)] transition-colors space-y-4">
          <h3 class="font-sans text-sm font-semibold text-zinc-950 dark:text-white transition-colors">
            Pre-flight checklist for {name} citizens.
          </h3>
          <p class="font-sans text-xs text-zinc-600 dark:text-zinc-300 leading-relaxed">
            Even when travelling to Visa-Free countries, travelers should compile a security entry checklist before booking flight paths:
          </p>
          <ul class="font-sans text-xs text-zinc-600 dark:text-zinc-300 space-y-3 list-disc pl-4">
            <li>
              <strong>Passport Validity:</strong> Verify that your passport has at least 6 months of validity remaining from your arrival date. Many airlines block check-in paths for passports expiring earlier.
            </li>
            <li>
              <strong>Blank Pages:</strong> Ensure your physical passport booklet has at least two blank stamp pages for border immigration clearance.
            </li>
            <li>
              <strong>Onward Travel Proof:</strong> Checkpoints in VoA or Visa-Free countries frequently audit proof of return or onward plane tickets.
            </li>
            <li>
              <strong>e-Visa/eTA Preparation:</strong> If your destination requires an eVisa or eTA, submit application rules at least 72 hours before your flight to prevent processing delays.
            </li>
          </ul>
        </div>
      </section>
    </div>
  </main>

  <Footer />

  <!-- Embed JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema, null, 2)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema, null, 2)} />

  <script>
    document.addEventListener("astro:page-load", () => {
      const searchInput = document.getElementById("dest-search") as HTMLInputElement;
      if (!searchInput) return;
      const rows = document.querySelectorAll(".dest-row") as NodeListOf<HTMLTableRowElement>;
      const mobileCards = document.querySelectorAll(".dest-card") as NodeListOf<HTMLDivElement>;
      const noResults = document.getElementById("no-dest-results") as HTMLDivElement;
      const desktopTableWrapper = document.getElementById("desktop-table-wrapper") as HTMLDivElement;
      const mobileCardsWrapper = document.getElementById("mobile-cards-wrapper") as HTMLDivElement;
      const filterBtns = document.querySelectorAll(".filter-btn") as NodeListOf<HTMLButtonElement>;

      let currentCategory = "all";
      let searchQuery = "";

      function filterDestinations() {
        if (!noResults) return;
        let visibleCount = 0;

        // Filter desktop table rows
        if (rows) {
          rows.forEach((row) => {
            const name = row.getAttribute("data-dest-name") || "";
            const code = row.getAttribute("data-dest-code") || "";
            const category = row.getAttribute("data-dest-category") || "";

            const matchesSearch = name.includes(searchQuery) || code.toLowerCase().includes(searchQuery);
            const matchesCategory = currentCategory === "all" || category === currentCategory;

            if (matchesSearch && matchesCategory) {
              row.classList.remove("hidden");
              visibleCount++;
            } else {
              row.classList.add("hidden");
            }
          });
        }

        // Filter mobile cards
        let mobileVisibleCount = 0;
        if (mobileCards) {
          mobileCards.forEach((card) => {
            const name = card.getAttribute("data-dest-name") || "";
            const code = card.getAttribute("data-dest-code") || "";
            const category = card.getAttribute("data-dest-category") || "";

            const matchesSearch = name.includes(searchQuery) || code.toLowerCase().includes(searchQuery);
            const matchesCategory = currentCategory === "all" || category === currentCategory;

            if (matchesSearch && matchesCategory) {
              card.classList.remove("hidden");
              mobileVisibleCount++;
            } else {
              card.classList.add("hidden");
            }
          });
        }

        // Determine final visible count depending on responsive layout view
        const isMobile = window.innerWidth < 768;
        const count = isMobile ? mobileVisibleCount : visibleCount;

        if (count === 0) {
          if (desktopTableWrapper) desktopTableWrapper.classList.add("hidden");
          if (mobileCardsWrapper) mobileCardsWrapper.classList.add("hidden");
          noResults.classList.remove("hidden");
        } else {
          if (desktopTableWrapper && !isMobile) desktopTableWrapper.classList.remove("hidden");
          if (mobileCardsWrapper && isMobile) mobileCardsWrapper.classList.remove("hidden");
          noResults.classList.add("hidden");
        }
      }

      if (searchInput) {
        searchInput.addEventListener("input", () => {
          searchQuery = searchInput.value.toLowerCase().trim();
          filterDestinations();
        });
      }

      filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          // Remove active styles from all buttons
          filterBtns.forEach((b) => {
            b.classList.remove("bg-zinc-950", "text-white", "dark:bg-white", "dark:text-black", "font-semibold");
            b.classList.add("text-zinc-500", "dark:text-zinc-400");
          });

          // Add active styles to clicked button
          btn.classList.add("bg-zinc-950", "text-white", "dark:bg-white", "dark:text-black", "font-semibold");
          btn.classList.remove("text-zinc-500", "dark:text-zinc-400");

          currentCategory = btn.getAttribute("data-filter") || "all";
          filterDestinations();
        });
      });

      // Handle window resize to adjust visibility of wrappers properly
      window.addEventListener("resize", () => {
        filterDestinations();
      });
    });
  </script>
</Layout>
