---
import Layout from '../layouts/Layout.astro';
const isDev = import.meta.env.DEV;
---

<Layout>
  <!-- Background Glow FX (Vercel atmospheric depth) -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-gradient-to-tr from-[#007cf0]/10 via-[#7928ca]/10 to-[#ff0080]/5 blur-[130px] pointer-events-none"></div>
  <div class="absolute bottom-10 right-1/4 w-[500px] h-[500px] rounded-full bg-gradient-to-br from-[#00dfd8]/5 via-[#f9cb28]/5 to-emerald-500/5 blur-[120px] pointer-events-none"></div>

  <!-- Header Nav -->
  <header class="sticky top-0 z-50 border-b border-zinc-900 bg-black/80 backdrop-blur-md">
    <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <!-- Minimal geometric logo mark -->
        <svg class="w-6 h-6 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2L2 22h20L12 2z" stroke-linejoin="round"></path>
        </svg>
        <span class="font-sans font-semibold tracking-tight text-white text-base">Global Visa Tracker</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="font-mono text-[10px] text-zinc-400 uppercase tracking-widest bg-zinc-900 border border-zinc-800 px-2 py-1 rounded">
          v1.0.0 Stable
        </span>
      </div>
    </div>
  </header>

  <!-- Main Hero Section -->
  <main class="max-w-5xl mx-auto px-4 pt-12 pb-24 relative">
    
    <!-- Title Area -->
    <div class="text-center md:text-left mb-10">
      <div class="inline-block mb-3 px-3 py-1 rounded-full border border-zinc-800 bg-zinc-900/60 font-mono text-xs text-zinc-400">
        Database Relational Lookup System
      </div>
      <h1 class="font-sans text-4xl md:text-5xl font-semibold tracking-tight text-white mb-4">
        Explore global travel parameters.
      </h1>
      <p class="font-sans text-zinc-400 text-lg max-w-2xl leading-relaxed">
        Select your origin and destination countries to cross-reference their bilateral visa outcome configurations in real-time.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Left side: Select Panel -->
      <section class="lg:col-span-5 space-y-6">
        <div class="p-6 rounded-lg border border-zinc-900 bg-[#080808] shadow-[0_1px_2px_rgba(0,0,0,0.4)]">
          <h2 class="font-sans text-lg font-medium text-white mb-6 flex items-center gap-2">
            <svg class="w-4 h-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Bilateral Query
          </h2>
          
          <form class="space-y-5" onsubmit="return false;">
            
            <!-- Origin Combobox -->
            <div class="space-y-2 relative">
              <label for="origin-input" class="block font-mono text-[11px] text-zinc-400 uppercase tracking-wider">
                Origin Nationality (Passport)
              </label>
              <div class="relative">
                <input 
                  type="text" 
                  id="origin-input" 
                  placeholder="Type to search origin..." 
                  class="w-full bg-[#0d0d0d] text-white border border-zinc-800 rounded px-3 py-3 font-sans text-sm focus:outline-none focus:border-zinc-500 transition-colors cursor-text"
                  autocomplete="off"
                  data-selected-code="US"
                  value="United States (US)"
                />
                <div class="absolute inset-y-0 right-0 flex items-center px-3 text-zinc-500 pointer-events-none">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </div>
              <!-- Dropdown Options List -->
              <div id="origin-dropdown" class="absolute z-20 w-full mt-1 max-h-60 overflow-y-auto rounded-md border border-zinc-800 bg-[#0d0d0d] hidden shadow-[0_10px_20px_-10px_rgba(0,0,0,0.7)] divide-y divide-zinc-900/50">
              </div>
            </div>

            <!-- Arrow icon separator -->
            <div class="flex justify-center py-1">
              <div class="w-8 h-8 rounded-full border border-zinc-800 bg-zinc-900/60 flex items-center justify-center text-zinc-500">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                </svg>
              </div>
            </div>

            <!-- Destination Combobox -->
            <div class="space-y-2 relative">
              <label for="destination-input" class="block font-mono text-[11px] text-zinc-400 uppercase tracking-wider">
                Destination Territory
              </label>
              <div class="relative">
                <input 
                  type="text" 
                  id="destination-input" 
                  placeholder="Type to search destination..." 
                  class="w-full bg-[#0d0d0d] text-white border border-zinc-800 rounded px-3 py-3 font-sans text-sm focus:outline-none focus:border-zinc-500 transition-colors cursor-text"
                  autocomplete="off"
                  data-selected-code="DE"
                  value="Germany (DE)"
                />
                <div class="absolute inset-y-0 right-0 flex items-center px-3 text-zinc-500 pointer-events-none">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </div>
              <!-- Dropdown Options List -->
              <div id="destination-dropdown" class="absolute z-20 w-full mt-1 max-h-60 overflow-y-auto rounded-md border border-zinc-800 bg-[#0d0d0d] hidden shadow-[0_10px_20px_-10px_rgba(0,0,0,0.7)] divide-y divide-zinc-900/50">
              </div>
            </div>
          </form>
        </div>

        <!-- Optional Direct Portal Apply Alert Box -->
        <div id="portal-link-container" class="hidden p-5 rounded-lg border border-blue-900/30 bg-blue-950/10 text-zinc-300 text-sm flex-col gap-3">
          <div class="flex items-center gap-2 text-blue-400 font-medium">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <span>Digital Application Portal Found</span>
          </div>
          <p class="text-zinc-400 leading-relaxed text-xs">
            This destination supports an online electronic application process. You can apply directly through the authorized government portal.
          </p>
          <a id="portal-link" href="#" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-full bg-zinc-900 border border-zinc-800 hover:border-zinc-700 text-white font-sans text-xs py-2 px-3 rounded mt-1 transition-colors">
            Access Application Portal
          </a>
        </div>
      </section>

      <!-- Right side: Matrix Output & PDF Viewer -->
      <section class="lg:col-span-7 space-y-8">
        
        <!-- Matrix Slabs -->
        <div class="p-6 rounded-lg border border-zinc-900 bg-[#080808] space-y-4">
          <div class="flex justify-between items-center mb-2">
            <h2 class="font-sans text-lg font-medium text-white">
              Visa Requirements Matrix
            </h2>
            <span class="font-mono text-[10px] text-zinc-500">
              ISO-2 Bilateral Output
            </span>
          </div>
          
          <div class="space-y-3">
            <!-- Slab 1: Visa-Free (Emerald) -->
            <div data-status-type="visa_free" class="relative flex flex-col md:flex-row items-start md:items-center justify-between p-5 rounded-lg border bg-gray-950/40 border-gray-800 opacity-30 transition-all duration-300 scale-100 ease-out">
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
                <div>
                  <div class="status-label font-sans font-semibold text-zinc-400 transition-colors duration-300">
                    Visa-Free Travel
                  </div>
                  <div class="text-[11px] text-zinc-500 mt-0.5">
                    Unrestricted bilateral transit access
                  </div>
                </div>
              </div>
              <!-- Hidden placeholder for stay duration -->
              <div class="stay-badge hidden mt-2 md:mt-0"></div>
            </div>

            <!-- Slab 2: e-Visa (Blue) -->
            <div data-status-type="evisa" class="relative flex flex-col md:flex-row items-start md:items-center justify-between p-5 rounded-lg border bg-gray-950/40 border-gray-800 opacity-30 transition-all duration-300 scale-100 ease-out">
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <div class="status-label font-sans font-semibold text-zinc-400 transition-colors duration-300">
                    e-Visa / Electronic Authorization
                  </div>
                  <div class="text-[11px] text-zinc-500 mt-0.5">
                    Pre-departure registration portal required
                  </div>
                </div>
              </div>
              <!-- Hidden placeholder for stay duration -->
              <div class="stay-badge hidden mt-2 md:mt-0"></div>
            </div>

            <!-- Slab 3: Visa on Arrival (Amber) -->
            <div data-status-type="visa_on_arrival" class="relative flex flex-col md:flex-row items-start md:items-center justify-between p-5 rounded-lg border bg-gray-950/40 border-gray-800 opacity-30 transition-all duration-300 scale-100 ease-out">
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-400">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <div class="status-label font-sans font-semibold text-zinc-400 transition-colors duration-300">
                    Visa on Arrival
                  </div>
                  <div class="text-[11px] text-zinc-500 mt-0.5">
                    Acquired at destination border terminal checkpoint
                  </div>
                </div>
              </div>
              <!-- Hidden placeholder for stay duration -->
              <div class="stay-badge hidden mt-2 md:mt-0"></div>
            </div>

            <!-- Slab 4: Embassy Visa (Rose) -->
            <div data-status-type="visa_required" class="relative flex flex-col md:flex-row items-start md:items-center justify-between p-5 rounded-lg border bg-gray-950/40 border-gray-800 opacity-30 transition-all duration-300 scale-100 ease-out">
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-rose-400">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                </div>
                <div>
                  <div class="status-label font-sans font-semibold text-zinc-400 transition-colors duration-300">
                    Embassy Visa Required
                  </div>
                  <div class="text-[11px] text-zinc-500 mt-0.5">
                    Physical consul interview or agency filing compulsory
                  </div>
                </div>
              </div>
              <!-- Hidden placeholder for stay duration -->
              <div class="stay-badge hidden mt-2 md:mt-0"></div>
            </div>
          </div>
        </div>

        <!-- PDF Embed Block -->
        <div class="p-6 rounded-lg border border-zinc-900 bg-[#080808] space-y-4">
          <div class="flex items-center justify-between">
            <h2 class="font-sans text-lg font-medium text-white flex items-center gap-2">
              <svg class="w-4 h-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Official Compliance Resources
            </h2>
            <span class="font-mono text-[10px] text-zinc-500 uppercase tracking-wider">
              Document Viewer
            </span>
          </div>

          <!-- Document embed frame wrapper -->
          <div class="relative w-full aspect-[4/3] md:aspect-[16/10] bg-[#0c0c0c] border border-zinc-800/80 rounded overflow-hidden">
            <iframe 
              id="compliance-pdf-viewer" 
              src="https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf" 
              class="w-full h-full border-0" 
              title="Official Visa Compliance Document">
            </iframe>
          </div>

          <div class="pt-2 flex justify-between items-center text-xs">
            <span class="text-zinc-500 font-sans">Can't see the document frame?</span>
            <a 
              id="compliance-external-link" 
              href="https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center gap-1.5 text-zinc-400 border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 px-3 py-1.5 rounded transition-all font-mono text-[11px]">
              <span>Open Document in Secure External Tab</span>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>

      </section>

    </div>
  </main>

  <!-- Sticky footer -->
  <footer class="border-t border-zinc-900 bg-black py-12">
    <div class="max-w-5xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-zinc-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2L2 22h20L12 2z" stroke-linejoin="round"></path>
        </svg>
        <span class="text-zinc-500 font-mono text-xs">GLOBAL VISA REQUIREMENTS MATRIX SYSTEM.</span>
      </div>
      <div class="flex gap-6 font-mono text-[11px] text-zinc-500">
        <span class="hover:text-zinc-300 cursor-pointer">Security Protocol</span>
        <span class="hover:text-zinc-300 cursor-pointer">Privacy System</span>
        <span class="hover:text-zinc-300 cursor-pointer">Government APIs</span>
      </div>
    </div>
  </footer>

  {isDev && (
    <div id="diagnostics-panel" class="fixed bottom-4 right-4 z-50 w-80 bg-zinc-950/95 border border-zinc-800 rounded-lg shadow-xl transition-all duration-300 font-mono text-[11px] overflow-hidden">
      <div id="diagnostics-header" class="flex items-center justify-between px-3 py-2 bg-zinc-900 border-b border-zinc-800 cursor-pointer select-none">
        <div class="flex items-center gap-2 text-zinc-300 font-semibold">
          <span class="w-1.5 h-1.5 rounded-full bg-[#007cf0] animate-pulse"></span>
          <span>Connection Diagnostics</span>
        </div>
        <button id="diagnostics-toggle" class="text-zinc-500 hover:text-zinc-300 transition-colors">
          <svg id="diagnostics-toggle-icon" class="w-3.5 h-3.5 transform transition-transform duration-300 rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>

      <div id="diagnostics-body" class="p-3 space-y-3">
        <div class="space-y-1">
          <div class="text-zinc-500 text-[10px] uppercase tracking-wider font-semibold">Database Ping</div>
          <div class="flex items-center justify-between">
            <span id="db-status-text" class="text-zinc-400">Pinging...</span>
            <span id="db-status-badge" class="px-1.5 py-0.5 rounded text-[10px] bg-zinc-900 border border-zinc-800 text-zinc-400 font-semibold">PENDING</span>
          </div>
        </div>

        <div class="space-y-1">
          <div class="text-zinc-500 text-[10px] uppercase tracking-wider font-semibold">RPC Fallback (XX -> YY)</div>
          <div class="flex items-center justify-between">
            <span id="rpc-status-text" class="text-zinc-400">Testing...</span>
            <span id="rpc-status-badge" class="px-1.5 py-0.5 rounded text-[10px] bg-zinc-900 border border-zinc-800 text-zinc-400 font-semibold">PENDING</span>
          </div>
        </div>

        <div class="space-y-1">
          <div class="text-zinc-500 text-[10px] uppercase tracking-wider font-semibold">Diagnostics Log</div>
          <pre id="diagnostics-log" class="w-full max-h-24 overflow-y-auto bg-black border border-zinc-900 rounded p-1.5 text-[10px] text-zinc-400 font-mono whitespace-pre-wrap select-text leading-tight">All systems operational.</pre>
        </div>
      </div>
    </div>
  )}

  <!-- Interactivity controller script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const originInput = document.getElementById('origin-input') as HTMLInputElement;
      const originDropdown = document.getElementById('origin-dropdown') as HTMLDivElement;
      const destinationInput = document.getElementById('destination-input') as HTMLInputElement;
      const destinationDropdown = document.getElementById('destination-dropdown') as HTMLDivElement;
      const slabs = document.querySelectorAll('[data-status-type]');
      const iframeViewer = document.getElementById('compliance-pdf-viewer') as HTMLIFrameElement;
      const externalLink = document.getElementById('compliance-external-link') as HTMLAnchorElement;
      const portalLinkContainer = document.getElementById('portal-link-container') as HTMLDivElement;
      const portalLink = document.getElementById('portal-link') as HTMLAnchorElement;

      // Fallback local countries catalog in case database fetch fails
      const fallbackCountries = [
        { code: "US", name: "United States (US)", flag: "🇺🇸" },
        { code: "DE", name: "Germany (DE)", flag: "🇩🇪" },
        { code: "IN", name: "India (IN)", flag: "🇮🇳" },
        { code: "SG", name: "Singapore (SG)", flag: "🇸🇬" },
        { code: "AE", name: "United Arab Emirates (AE)", flag: "🇦🇪" }
      ];

      // Dynamic list populated from database
      let countries = [...fallbackCountries];

      // Supabase Client Config (Fallback values provided; override with environment tokens if needed)
      const SUPABASE_URL = (window as any).PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL || 'https://your-supabase-project.supabase.co';
      const SUPABASE_ANON_KEY = (window as any).PUBLIC_SUPABASE_ANON_KEY || import.meta.env.PUBLIC_SUPABASE_ANON_KEY || 'your-supabase-anon-key';

      // Convert ISO code to flag emoji dynamically
      function getFlagEmoji(countryCode: string) {
        if (!countryCode || countryCode.length !== 2) return "🏳️";
        const codePoints = countryCode
          .toUpperCase()
          .split('')
          .map(char => 127397 + char.charCodeAt(0));
        try {
          return String.fromCodePoint(...codePoints);
        } catch (e) {
          return "🏳️";
        }
      }

      // Fetch all countries dynamically from Supabase countries table
      async function fetchCountries() {
        const url = `${SUPABASE_URL}/rest/v1/countries?select=iso_code,name&order=name`;
        const response = await fetch(url, {
          method: 'GET',
          headers: {
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
          }
        });
        if (!response.ok) {
          throw new Error(`Countries fetch failed with status: ${response.status}`);
        }
        const data = await response.json();
        if (Array.isArray(data)) {
          return data.map(item => ({
            code: item.iso_code,
            name: `${item.name} (${item.iso_code})`,
            flag: getFlagEmoji(item.iso_code)
          }));
        }
        throw new Error('Malformed countries payload');
      }

      // Clean fetch wrapper mapping active ISO tokens directly toward Supabase RPC endpoint
      async function queryDatabaseRpc(originIso: string, destinationIso: string) {
        const url = `${SUPABASE_URL}/rest/v1/rpc/get_visa_requirement`;

        const response = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
          },
          body: JSON.stringify({
            p_origin_iso: originIso,
            p_destination_iso: destinationIso
          })
        });

        if (!response.ok) {
          throw new Error(`Database lookup request failed with status: ${response.status}`);
        }

        const data = await response.json();
        
        // RPC returns setof table format (an array containing exactly one matching row)
        if (Array.isArray(data) && data.length > 0) {
          return data[0];
        } else if (data && !Array.isArray(data)) {
          return data;
        }
        
        throw new Error('Malformed or empty database response payload');
      }

      async function checkStatus() {
        const origin = originInput.getAttribute('data-selected-code');
        const destination = destinationInput.getAttribute('data-selected-code');

        if (!origin || !destination) return;

        // Clean Reset routine for all slabs (opacity-30, border-gray-800, scale-100, remove shadows)
        slabs.forEach(slab => {
          slab.classList.remove('opacity-100', 'scale-[1.01]', 'shadow-glow-emerald', 'shadow-glow-blue', 'shadow-glow-amber', 'shadow-glow-rose', 'border-emerald-500/50', 'border-blue-500/50', 'border-amber-500/50', 'border-rose-500/50');
          slab.classList.add('opacity-30', 'scale-100');

          // Reset status label text colors to muted state
          const textLabel = slab.querySelector('.status-label');
          if (textLabel) {
            textLabel.classList.remove('text-emerald-400', 'text-blue-400', 'text-amber-400', 'text-rose-500');
            textLabel.classList.add('text-zinc-400');
          }

          // Hide duration text badges
          const stayBadge = slab.querySelector('.stay-badge');
          if (stayBadge) {
            stayBadge.classList.add('hidden');
            stayBadge.textContent = '';
          }
        });

        let outcome;
        try {
          // Fire asynchronous request dynamically to DB backend
          outcome = await queryDatabaseRpc(origin, destination);
        } catch (error) {
          console.warn("Supabase database RPC failed. Falling back gracefully to default 'visa_required' configuration.", error);
          // Clean catch state block: graceful fallback
          outcome = {
            status_type: "visa_required",
            max_stay_days: 0,
            official_pdf_url: "https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf"
          };
        }

        // Pass payload variables straight to highlighting state engine
        highlightVisaSlab(outcome ? outcome.status_type : 'visa_required', outcome ? outcome.max_stay_days : 0, outcome ? outcome.official_pdf_url : '');
      }

      // Collapsible Diagnostics Panel Handler
      const diagPanel = document.getElementById('diagnostics-panel');
      const diagHeader = document.getElementById('diagnostics-header');
      const diagBody = document.getElementById('diagnostics-body');
      const diagToggleIcon = document.getElementById('diagnostics-toggle-icon');

      if (diagHeader && diagBody && diagToggleIcon) {
        let isExpanded = localStorage.getItem('diag_expanded') !== 'false';
        
        const updatePanelState = () => {
          if (isExpanded) {
            diagBody.classList.remove('hidden');
            diagToggleIcon.classList.add('rotate-180');
          } else {
            diagBody.classList.add('hidden');
            diagToggleIcon.classList.remove('rotate-180');
          }
        };

        updatePanelState();

        diagHeader.addEventListener('click', () => {
          isExpanded = !isExpanded;
          localStorage.setItem('diag_expanded', String(isExpanded));
          updatePanelState();
        });
      }

      // Run Connection Diagnostics
      async function runDiagnostics() {
        const dbText = document.getElementById('db-status-text');
        const dbBadge = document.getElementById('db-status-badge');
        const rpcText = document.getElementById('rpc-status-text');
        const rpcBadge = document.getElementById('rpc-status-badge');
        const logArea = document.getElementById('diagnostics-log');

        if (!dbText || !dbBadge || !rpcText || !rpcBadge || !logArea) return;

        let logContent = '';
        const appendLog = (msg: string) => {
          logContent += msg + '\n';
          logArea.textContent = logContent.trim() || 'All systems operational.';
        };

        // Test 1: Ping Supabase Countries
        try {
          dbText.textContent = 'Pinging Database...';
          const pingStart = performance.now();
          const response = await fetch(`${SUPABASE_URL}/rest/v1/countries?select=iso_code`, {
            method: 'GET',
            headers: {
              'apikey': SUPABASE_ANON_KEY,
              'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
            }
          });
          const latency = Math.round(performance.now() - pingStart);

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }

          const data = await response.json();
          if (!Array.isArray(data)) {
            throw new Error('Database returned invalid payload format');
          }

          dbText.textContent = `Connected (${latency}ms)`;
          dbBadge.textContent = 'CONNECTED';
          dbBadge.className = 'px-1.5 py-0.5 rounded text-[10px] font-semibold bg-emerald-500/10 border border-emerald-500/20 text-emerald-400';
          appendLog(`[DB] Successfully fetched ${data.length} countries.`);
        } catch (err: any) {
          dbText.textContent = 'Connection Failed';
          dbBadge.textContent = 'FAILED';
          dbBadge.className = 'px-1.5 py-0.5 rounded text-[10px] font-semibold bg-rose-500/10 border border-rose-500/20 text-rose-400';
          appendLog(`[DB ERROR] ${err.message || err}`);
        }

        // Test 2: RPC Fallback Validation
        try {
          rpcText.textContent = 'Testing RPC Fallback...';
          const rpcStart = performance.now();
          const response = await fetch(`${SUPABASE_URL}/rest/v1/rpc/get_visa_requirement`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'apikey': SUPABASE_ANON_KEY,
              'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
            },
            body: JSON.stringify({
              p_origin_iso: 'XX',
              p_destination_iso: 'YY'
            })
          });
          const latency = Math.round(performance.now() - rpcStart);

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }

          const data = await response.json();
          const outcome = Array.isArray(data) ? data[0] : data;

          if (!outcome || outcome.status_type !== 'visa_required') {
            throw new Error(`Expected visa_required fallback, got ${JSON.stringify(outcome)}`);
          }

          rpcText.textContent = `Passed (${latency}ms)`;
          rpcBadge.textContent = 'PASSED';
          rpcBadge.className = 'px-1.5 py-0.5 rounded text-[10px] font-semibold bg-emerald-500/10 border border-emerald-500/20 text-emerald-400';
          appendLog(`[RPC] Fallback test succeeded. Returned 'visa_required'.`);
        } catch (err: any) {
          rpcText.textContent = 'RPC Failed';
          rpcBadge.textContent = 'FAILED';
          rpcBadge.className = 'px-1.5 py-0.5 rounded text-[10px] font-semibold bg-rose-500/10 border border-rose-500/20 text-rose-400';
          appendLog(`[RPC ERROR] ${err.message || err}`);
        }
      }

      if (diagPanel) {
        runDiagnostics();
      }

      function highlightVisaSlab(statusType: string, maxStayDays: number, officialPdfUrl: string) {
        // Map database enum outcomes to frontend UI layout outcome markers
        let uiStatusType = statusType || 'visa_required';
        if (uiStatusType === 'voa') {
          uiStatusType = 'visa_on_arrival';
        }

        const validStatuses = ['visa_free', 'evisa', 'visa_on_arrival', 'visa_required'];
        if (!validStatuses.includes(uiStatusType)) {
          uiStatusType = 'visa_required';
        }

        const activeSlab = document.querySelector(`[data-status-type="${uiStatusType}"]`) as HTMLDivElement;
        if (activeSlab) {
          activeSlab.classList.remove('opacity-30', 'scale-100');
          activeSlab.classList.add('opacity-100', 'scale-[1.01]');

          const textLabel = activeSlab.querySelector('.status-label');
          if (textLabel) {
            textLabel.classList.remove('text-zinc-400');
          }

          // Apply specific glowing shadows, active borders, and color schemes
          if (uiStatusType === 'visa_free') {
            activeSlab.classList.add('shadow-glow-emerald', 'border-emerald-500/50');
            if (textLabel) textLabel.classList.add('text-emerald-400');
          } else if (uiStatusType === 'evisa') {
            activeSlab.classList.add('shadow-glow-blue', 'border-blue-500/50');
            if (textLabel) textLabel.classList.add('text-blue-400');
          } else if (uiStatusType === 'visa_on_arrival') {
            activeSlab.classList.add('shadow-glow-amber', 'border-amber-500/50');
            if (textLabel) textLabel.classList.add('text-amber-400');
          } else if (uiStatusType === 'visa_required') {
            activeSlab.classList.add('shadow-glow-rose', 'border-rose-500/50');
            if (textLabel) textLabel.classList.add('text-rose-500');
          }

          // Unhide right-hand duration text container and append max allowed stay
          const stayBadge = activeSlab.querySelector('.stay-badge') as HTMLDivElement;
          if (stayBadge && maxStayDays > 0) {
            stayBadge.classList.remove('hidden');
            stayBadge.textContent = `Max Allowed Stay: ${maxStayDays} Days`;
            
            // Assign specific colored classes to the stay badge to match theme
            if (uiStatusType === 'visa_free') {
              stayBadge.className = 'stay-badge text-[11px] font-mono px-3 py-1 rounded-full border bg-emerald-500/10 text-emerald-400 border-emerald-500/20';
            } else if (uiStatusType === 'evisa') {
              stayBadge.className = 'stay-badge text-[11px] font-mono px-3 py-1 rounded-full border bg-blue-500/10 text-blue-400 border-blue-500/20';
            } else if (uiStatusType === 'visa_on_arrival') {
              stayBadge.className = 'stay-badge text-[11px] font-mono px-3 py-1 rounded-full border bg-amber-500/10 text-amber-400 border-amber-500/20';
            }
          }
        }

        // Dynamically assign PDF URL parameter directly to the active source path of the viewer
        const pdfUrl = officialPdfUrl || 'https://www.w3.org/WAI/ER/tests/xhtml/testfiles/resources/pdf/dummy.pdf';
        if (iframeViewer) {
          iframeViewer.src = pdfUrl;
        }

        // Update target URL for the external tab anchor link
        if (externalLink) {
          externalLink.href = pdfUrl;
        }

        // Dynamically construct digital application portals matching specific eVisa destinations
        const origin = originInput.getAttribute('data-selected-code') || '';
        const destination = destinationInput.getAttribute('data-selected-code') || '';
        let portalUrl = "";

        if (uiStatusType === 'evisa') {
          if (origin === 'US' && destination === 'IN') portalUrl = "https://indianvisaonline.gov.in/evisa/tvoa.html";
          else if (origin === 'DE' && destination === 'IN') portalUrl = "https://indianvisaonline.gov.in/evisa/tvoa.html";
          else if (origin === 'SG' && destination === 'IN') portalUrl = "https://indianvisaonline.gov.in/evisa/tvoa.html";
          else if (origin === 'AE' && destination === 'IN') portalUrl = "https://indianvisaonline.gov.in/evisa/tvoa.html";
          else if (origin === 'DE' && destination === 'US') portalUrl = "https://esta.cbp.dhs.gov/";
          else if (origin === 'SG' && destination === 'US') portalUrl = "https://esta.cbp.dhs.gov/";
          else if (origin === 'IN' && destination === 'SG') portalUrl = "https://www.ica.gov.sg/enter-transit-depart/entering-singapore/visa_requirements";
        }

        if (portalLinkContainer && portalLink) {
          if (portalUrl) {
            portalLink.href = portalUrl;
            portalLinkContainer.classList.remove('hidden');
            portalLinkContainer.classList.add('flex');
          } else {
            portalLinkContainer.classList.remove('flex');
            portalLinkContainer.classList.add('hidden');
          }
        }
      }

      function setupCombobox(input: HTMLInputElement, dropdown: HTMLDivElement) {
        function renderOptions(filterText = '') {
          dropdown.innerHTML = '';
          const filtered = countries.filter(c => 
            c.name.toLowerCase().includes(filterText.toLowerCase()) || 
            c.code.toLowerCase().includes(filterText.toLowerCase())
          );

          if (filtered.length === 0) {
            const noMatch = document.createElement('div');
            noMatch.className = 'px-4 py-3 text-xs text-zinc-500 italic';
            noMatch.textContent = 'No matching countries';
            dropdown.appendChild(noMatch);
            return;
          }

          filtered.forEach(c => {
            const option = document.createElement('div');
            option.className = 'px-4 py-3 text-sm text-zinc-300 hover:bg-zinc-900 hover:text-white cursor-pointer transition-colors flex items-center gap-2';
            option.innerHTML = `<span>${c.flag}</span> <span>${c.name}</span>`;
            
            option.addEventListener('mousedown', (e) => {
              e.preventDefault(); // prevent input blur before selection
              selectOption(c);
            });
            dropdown.appendChild(option);
          });
        }

        function selectOption(country: typeof countries[number]) {
          input.value = country.name;
          input.setAttribute('data-selected-code', country.code);
          hideDropdown();
          checkStatus();
        }

        function showDropdown() {
          dropdown.classList.remove('hidden');
          renderOptions(input.value);
        }

        function hideDropdown() {
          dropdown.classList.add('hidden');
        }

        input.addEventListener('focus', showDropdown);
        input.addEventListener('click', showDropdown);
        input.addEventListener('input', showDropdown);
        
        input.addEventListener('blur', () => {
          // Revert back to match code name if input is left blank or has mismatch
          const code = input.getAttribute('data-selected-code');
          const current = countries.find(c => c.code === code);
          if (current) {
            input.value = current.name;
          }
          setTimeout(hideDropdown, 150); // slight delay to allow mousedown to trigger first
        });
      }

      async function initializeApp() {
        try {
          // Attempt to load the complete country list dynamically from Supabase database
          const liveCountries = await fetchCountries();
          if (liveCountries && liveCountries.length > 0) {
            countries = liveCountries;
            
            // Sync current inputs with newly loaded database list
            const originCode = originInput.getAttribute('data-selected-code');
            const destCode = destinationInput.getAttribute('data-selected-code');

            const originCountry = countries.find(c => c.code === originCode);
            if (originCountry) originInput.value = originCountry.name;

            const destCountry = countries.find(c => c.code === destCode);
            if (destCountry) destinationInput.value = destCountry.name;
          }
        } catch (error) {
          console.warn("Could not load countries from live Supabase table. Utilizing static fallback list.", error);
        }

        // Initialize both searchable comboboxes
        setupCombobox(originInput, originDropdown);
        setupCombobox(destinationInput, destinationDropdown);

        // Perform initial check on application mount
        checkStatus();
      }

      // Start the application initialization
      initializeApp();
    });
  </script>
</Layout>
