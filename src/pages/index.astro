  <!-- Interactivity controller script -->
  <script>
    import visaDataMatrix from "../data/passport-index.json";
    import officialPortals from "../data/official-portals.json";

    document.addEventListener("DOMContentLoaded", () => {
      const originInput = document.getElementById(
        "origin-input",
      ) as HTMLInputElement;
      const originDropdown = document.getElementById(
        "origin-dropdown",
      ) as HTMLDivElement;
      const destinationInput = document.getElementById(
        "destination-input",
      ) as HTMLInputElement;
      const destinationDropdown = document.getElementById(
        "destination-dropdown",
      ) as HTMLDivElement;
      const slabs = document.querySelectorAll("[data-status-type]");
      const portalLinkContainer = document.getElementById(
        "portal-link-container",
      ) as HTMLDivElement;
      const portalLink = document.getElementById(
        "portal-link",
      ) as HTMLAnchorElement;
      const sameCountryWarning = document.getElementById(
        "same-country-warning",
      ) as HTMLDivElement;
      const detailContainer = document.getElementById(
        "detail-on-demand-container",
      ) as HTMLDivElement;
      const detailsToggleBtn = document.getElementById(
        "details-toggle-btn",
      ) as HTMLButtonElement;
      const detailsPanel = document.getElementById(
        "details-panel",
      ) as HTMLDivElement;
      const detailsChevron = document.getElementById(
        "details-chevron",
      ) as HTMLElement;
      const detailsDate = document.getElementById(
        "details-date",
      ) as HTMLSpanElement;
      const officialSourceLink = document.getElementById(
        "official-source-link",
      ) as HTMLAnchorElement;
      const complianceBanner = document.getElementById(
        "compliance-banner-container",
      ) as HTMLDivElement;
      const themeToggleBtn = document.getElementById("theme-toggle");

      // Accordion Toggle Logic
      function collapseDetails() {
        if (detailsPanel && detailsChevron && detailsToggleBtn) {
          detailsPanel.style.maxHeight = "0px";
          detailsPanel.classList.remove("opacity-100");
          detailsPanel.classList.add("opacity-0");
          detailsChevron.classList.remove("rotate-180");
          detailsToggleBtn.setAttribute("aria-expanded", "false");
          const toggleText = detailsToggleBtn.querySelector("span");
          if (toggleText) {
            toggleText.textContent = "Click to expand details";
          }
          setTimeout(() => {
            if (detailsToggleBtn.getAttribute("aria-expanded") === "false") {
              detailsPanel.classList.add("hidden");
            }
          }, 300);
        }
      }

      if (detailsToggleBtn) {
        detailsToggleBtn.addEventListener("click", () => {
          if (!detailsPanel || !detailsChevron) return;
          const isExpanded = detailsToggleBtn.getAttribute("aria-expanded") === "true";
          if (isExpanded) {
            collapseDetails();
          } else {
            detailsPanel.classList.remove("hidden");
            // Force layout reflow to trigger transition
            detailsPanel.offsetHeight;
            detailsPanel.style.maxHeight = `${detailsPanel.scrollHeight}px`;
            detailsPanel.classList.remove("opacity-0");
            detailsPanel.classList.add("opacity-100");
            detailsChevron.classList.add("rotate-180");
            detailsToggleBtn.setAttribute("aria-expanded", "true");
            const toggleText = detailsToggleBtn.querySelector("span");
            if (toggleText) {
              toggleText.textContent = "Click to collapse details";
            }
          }
        });
      }

      // Theme Toggle Event Listener
      if (themeToggleBtn) {
        themeToggleBtn.addEventListener("click", () => {
          const isDark = document.documentElement.classList.contains("dark");
          if (isDark) {
            document.documentElement.classList.remove("dark");
            localStorage.setItem("theme", "light");
          } else {
            document.documentElement.classList.add("dark");
            localStorage.setItem("theme", "dark");
          }
        });
      }

      // Swap Countries Event Listener
      const swapCountriesBtn = document.getElementById("swap-countries-btn");
      if (swapCountriesBtn) {
        swapCountriesBtn.addEventListener("click", () => {
          const originCode = originInput.getAttribute("data-selected-code");
          const originVal = originInput.value;
          const destCode = destinationInput.getAttribute("data-selected-code");
          const destVal = destinationInput.value;

          // Swap values
          originInput.value = destVal;
          destinationInput.value = originVal;

          // Swap code attributes
          if (destCode) {
            originInput.setAttribute("data-selected-code", destCode);
          } else {
            originInput.removeAttribute("data-selected-code");
          }

          if (originCode) {
            destinationInput.setAttribute("data-selected-code", originCode);
          } else {
            destinationInput.removeAttribute("data-selected-code");
          }

          // Trigger update
          checkStatus();
        });
      }

      // Helper to check if string is numeric (represents days/duration)
      const isNumerical = (str: string) => /^\d+$/.test(str);

      // Convert ISO-2 country code to flag emoji
      function getFlagEmoji(countryCode: string) {
        if (!countryCode || countryCode.length !== 2) return "🏳️";
        const codePoints = countryCode
          .toUpperCase()
          .split("")
          .map((char) => 127397 + char.charCodeAt(0));
        try {
          return String.fromCodePoint(...codePoints);
        } catch (e) {
          return "🏳️";
        }
      }

      // Generate the dynamic countries list from the JSON keys using Intl.DisplayNames
      let countries: { code: string; name: string; flag: string }[] = [];
      try {
        const regionNames = new Intl.DisplayNames(["en"], { type: "region" });
        countries = Object.keys(visaDataMatrix)
          .map((code) => {
            let name = code;
            try {
              name = regionNames.of(code) || code;
            } catch (e) {}
            return {
              code: code,
              name: `${name} (${code})`,
              flag: getFlagEmoji(code),
            };
          })
          .sort((a, b) => a.name.localeCompare(b.name));
      } catch (err) {
        console.error(
          "Failed to initialize countries list via Intl.DisplayNames:",
          err,
        );
      }

      const defaultTitle =
        "Can I Fly There? | Instant Visa Requirement Checker";
      const defaultDescription =
        "Instant visa requirement checker for international travelers. Verify bilateral visa rules, stay limits, and visa on arrival eligibility for 197+ countries instantly.";

      function getVisaStatusFriendly(origin: string, destination: string) {
        if (!visaDataMatrix[origin as keyof typeof visaDataMatrix])
          return "Visa Required";
        const rule = (
          visaDataMatrix[origin as keyof typeof visaDataMatrix] as any
        )[destination];
        if (!rule) return "Visa Required";
        const status = rule.status ? rule.status.toLowerCase() : "";
        const days = rule.days ? parseInt(rule.days) : 0;

        if (status === "visa free" || !isNaN(Number(status))) {
          return `Visa-Free (${status === "visa free" ? (days ? days + " Days" : "Yes") : status + " Days"})`;
        } else if (status === "eta" || status === "e-visa") {
          return `eVisa (${days ? days + " Days" : "Yes"})`;
        } else if (status === "visa on arrival") {
          return `Visa on Arrival (${days ? days + " Days" : "Yes"})`;
        }
        return "Visa Required";
      }

      function updateFAQSchema(originName: string, originCode: string) {
        const faqSchema = document.getElementById("faq-schema");
        if (!faqSchema) return;

        let q3Name = "Do I need a visa to go to Japan, Mexico, or Italy?";
        let q3Answer =
          "Visa criteria for Japan, Mexico, and Italy vary completely based on your passport's country of origin. Use our instant lookup scanner above to cross-reference your specific nationality against these destinations instantly.";

        if (originName && originCode) {
          q3Name = `Do I need a visa to go to Japan, Mexico, or Italy from ${originName}?`;
          const jpStatus = getVisaStatusFriendly(originCode, "JP");
          const mxStatus = getVisaStatusFriendly(originCode, "MX");
          const itStatus = getVisaStatusFriendly(originCode, "IT");
          q3Answer = `Based on your selected passport (${originName}): Japan status: ${jpStatus}; Mexico status: ${mxStatus}; Italy status: ${itStatus}. Use our instant lookup scanner above to cross-reference your specific nationality against any destination instantly.`;
        }

        const schemaData = {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          mainEntity: [
            {
              "@type": "Question",
              name: "Do I need a visa if I already hold a valid passport?",
              acceptedAnswer: {
                "@type": "Answer",
                text: "A passport is required for all international travel, but it does not guarantee entry. Visa requirements depend strictly on your nationality and the bilateral agreements between your home country and your destination.",
              },
            },
            {
              "@type": "Question",
              name: "What are the different global visa requirement categories?",
              acceptedAnswer: {
                "@type": "Answer",
                text: "Entry rules typically fall into four distinct tiers: Visa-Free (no prior approval needed), eVisa (electronic application processed online before departure), Visa on Arrival (issued instantly at the border checkpoint), and Embassy Visa Required (traditional paper application needed before flying).",
              },
            },
            {
              "@type": "Question",
              name: q3Name,
              acceptedAnswer: {
                "@type": "Answer",
                text: q3Answer,
              },
            },
          ],
        };

        faqSchema.textContent = JSON.stringify(schemaData, null, 2);
      }

      function updateDynamicFAQ(origin: string | null) {
        const faqQ3Text = document.getElementById("faq-q3-text");
        const faqA3Text = document.getElementById("faq-a3-text");

        if (!faqQ3Text || !faqA3Text) return;

        if (origin) {
          const originCountry = countries.find((c) => c.code === origin);
          const originName = originCountry
            ? originCountry.name.split(" (")[0]
            : origin;

          faqQ3Text.textContent = `Do I need a visa to go to Japan, Mexico, or Italy from ${originName}?`;

          const jpStatus = getVisaStatusFriendly(origin, "JP");
          const mxStatus = getVisaStatusFriendly(origin, "MX");
          const itStatus = getVisaStatusFriendly(origin, "IT");

          faqA3Text.innerHTML = `
            Based on your selected passport (<strong>${originName}</strong>):
            <ul class="list-disc pl-5 mt-2 space-y-1 font-mono text-[11px] text-zinc-700 dark:text-zinc-300">
              <li>Japan: <span class="text-zinc-950 dark:text-white font-semibold">${jpStatus}</span></li>
              <li>Mexico: <span class="text-zinc-950 dark:text-white font-semibold">${mxStatus}</span></li>
              <li>Italy: <span class="text-zinc-950 dark:text-white font-semibold">${itStatus}</span></li>
            </ul>
            <p class="mt-3">Use our instant lookup scanner above to cross-reference your specific nationality against any destination instantly.</p>
          `;

          updateFAQSchema(originName, origin);
        } else {
          faqQ3Text.textContent =
            "Do I need a visa to go to Japan, Mexico, or Italy?";
          faqA3Text.innerHTML =
            "Visa criteria for Japan, Mexico, and Italy vary completely based on your passport's country of origin. Use our instant lookup scanner above to cross-reference your specific nationality against these destinations instantly.";
          updateFAQSchema("", "");
        }
      }

      function resetSEO() {
        document.title = defaultTitle;
        const metaDesc = document.querySelector('meta[name="description"]');
        if (metaDesc) {
          metaDesc.setAttribute("content", defaultDescription);
        }
        updateDynamicFAQ(null);
      }

      function checkStatus() {
        const origin = originInput.getAttribute("data-selected-code");
        const destination = destinationInput.getAttribute("data-selected-code");

        // Dynamic update of FAQ based on origin selection alone
        updateDynamicFAQ(origin);

        if (!origin || !destination) {
          if (detailContainer) {
            detailContainer.classList.add("hidden");
            collapseDetails();
          }
          if (complianceBanner) {
            complianceBanner.classList.add("hidden");
          }
          hideNewsSection();
          resetSEO();
          return;
        }

        // Reset warning display
        if (sameCountryWarning) {
          sameCountryWarning.classList.add("hidden");
        }

        // Clean Reset routine for all slabs
        if (detailContainer) {
          detailContainer.classList.add("hidden");
          collapseDetails();
        }

        slabs.forEach((slab) => {
          slab.classList.remove(
            "opacity-100",
            "scale-[1.02]",
            "shadow-glow-emerald",
            "shadow-glow-blue",
            "shadow-glow-amber",
            "shadow-glow-rose",
            "border-emerald-500/50",
            "border-blue-500/50",
            "border-amber-500/50",
            "border-rose-500/50",
          );
          slab.classList.add("opacity-30", "scale-100");

          const textLabel = slab.querySelector(".status-label");
          if (textLabel) {
            textLabel.classList.remove(
              "text-emerald-600",
              "dark:text-emerald-400",
              "text-blue-600",
              "dark:text-blue-400",
              "text-amber-600",
              "dark:text-amber-400",
              "text-rose-600",
              "dark:text-rose-450",
              "text-emerald-400",
              "text-blue-400",
              "text-amber-400",
              "text-rose-500",
              "text-emerald-800",
              "dark:text-emerald-300",
              "text-blue-800",
              "dark:text-blue-300",
              "text-amber-800",
              "dark:text-amber-300",
              "text-rose-800",
              "dark:text-rose-300",
            );
            textLabel.classList.add("text-zinc-500", "dark:text-zinc-400");
          }

          const descLabel = slab.querySelector(".status-desc");
          if (descLabel) {
            descLabel.classList.remove("text-zinc-800", "dark:text-zinc-200");
            descLabel.classList.add("text-zinc-500", "dark:text-zinc-500");
          }

          const stayBadge = slab.querySelector(".stay-badge");
          if (stayBadge) {
            stayBadge.classList.add("hidden");
            stayBadge.textContent = "";
          }
        });

        // Strict validation: origin cannot be destination
        if (origin === destination) {
          if (sameCountryWarning) {
            sameCountryWarning.classList.remove("hidden");
          }
          if (portalLinkContainer) {
            portalLinkContainer.classList.remove("flex");
            portalLinkContainer.classList.add("hidden");
          }
          if (detailContainer) {
            detailContainer.classList.add("hidden");
            collapseDetails();
          }
          if (complianceBanner) {
            complianceBanner.classList.add("hidden");
          }
          hideNewsSection();
          resetSEO();
          return;
        }

        // Lookup in-memory matrix
        let outcome = {
          status_type: "visa_required",
          max_stay_days: 0,
        };

        if (
          visaDataMatrix[origin as keyof typeof visaDataMatrix] &&
          (visaDataMatrix[origin as keyof typeof visaDataMatrix] as any)[
            destination
          ]
        ) {
          const rule = (
            visaDataMatrix[origin as keyof typeof visaDataMatrix] as any
          )[destination];
          const status = rule.status ? rule.status.toLowerCase() : "";
          const days = rule.days ? parseInt(rule.days) : 0;

          if (status === "visa free" || isNumerical(status)) {
            outcome.status_type = "visa_free";
            outcome.max_stay_days = isNumerical(status)
              ? parseInt(status)
              : days;
          } else if (status === "eta" || status === "e-visa") {
            outcome.status_type = "evisa";
            outcome.max_stay_days = days;
          } else if (status === "visa on arrival") {
            outcome.status_type = "visa_on_arrival";
            outcome.max_stay_days = days;
          } else if (status === "visa required") {
            outcome.status_type = "visa_required";
            outcome.max_stay_days = 0;
          }
        }

        // Collapse virtual keyboards instantly on iOS and Android
        if (document.activeElement instanceof HTMLElement) {
          document.activeElement.blur();
        }

        highlightVisaSlab(outcome.status_type, outcome.max_stay_days);

        const originCountry = countries.find((c) => c.code === origin);
        const destCountry = countries.find((c) => c.code === destination);
        const originName = originCountry
          ? originCountry.name.split(" (")[0]
          : origin || "";
        const destinationName = destCountry
          ? destCountry.name.split(" (")[0]
          : destination || "";

        // Dynamic Title Template
        document.title = `Do citizens of ${originName} need a visa for ${destinationName}? | Can I Fly There?`;

        // Dynamic Meta Description Template
        const metaDesc = document.querySelector('meta[name="description"]');
        if (metaDesc) {
          metaDesc.setAttribute(
            "content",
            `${originName} to ${destinationName} tourist visa rules, max stay limits, and visa on arrival requirements for ${originName} passport holding travelers. Verify official bilateral entry guidelines instantly.`,
          );
        }

        // Resolve external official reference URL and update detail container
        if (detailContainer && officialSourceLink) {
          const destDomain = officialPortals[destination as keyof typeof officialPortals];
          const finalUrl =
            destDomain ||
            `https://en.wikipedia.org/wiki/Visa_policy_of_${encodeURIComponent(destinationName.replace(/\s+/g, "_"))}`;

          officialSourceLink.href = finalUrl;

          const sourceLinkText = officialSourceLink.querySelector("span");
          if (sourceLinkText) {
            if (destDomain) {
              sourceLinkText.textContent = `Official Government Portal of ${destinationName}`;
            } else {
              sourceLinkText.textContent = `Visa Policy of ${destinationName} (Wikipedia)`;
            }
          }

          // Format dynamic date
          if (detailsDate) {
            const today = new Date();
            const dateStr = today.toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
              year: "numeric"
            });
            detailsDate.textContent = `${dateStr} at 06:00 UTC`;
          }

          detailContainer.classList.remove("hidden");
        }

        if (complianceBanner) {
          complianceBanner.classList.remove("hidden");
        }

        // Fetch relevant news
        fetchNews(origin, destination);

        // Auto-scroll to results container if it is not fully visible on the screen
        const resultsContainer = document.getElementById("results-container");
        if (resultsContainer) {
          setTimeout(() => {
            const rect = resultsContainer.getBoundingClientRect();
            const viewportHeight =
              window.innerHeight || document.documentElement.clientHeight;

            // Check if the entire results container is within the viewport
            const isFullyVisible =
              rect.top >= 0 && rect.bottom <= viewportHeight;

            if (!isFullyVisible) {
              if (rect.height <= viewportHeight) {
                // If it can fit on the screen fully, center it
                resultsContainer.scrollIntoView({
                  behavior: "smooth",
                  block: "center",
                });
              } else {
                // If it's too tall for the viewport, scroll to start so the user sees the top
                resultsContainer.scrollIntoView({
                  behavior: "smooth",
                  block: "start",
                });
              }
            }
          }, 180); // 150ms-200ms delay to allow keyboard tray to close fully
        }
      }

      function hideNewsSection() {
        const container = document.getElementById("news-section-container");
        if (container) {
          container.classList.add("hidden");
        }
      }

      function displayNews(items: any[]) {
        const container = document.getElementById("news-section-container");
        const newsList = document.getElementById("news-list");
        if (!container || !newsList) return;

        newsList.innerHTML = "";

        // Show at most 3 items
        const itemsToShow = items.slice(0, 3);

        itemsToShow.forEach((item, index) => {
          const div = document.createElement("div");
          div.className = `${index > 0 ? "pt-4 border-t border-zinc-150 dark:border-zinc-900/50" : ""} pb-1`;

          let dateStr = "";
          try {
            const date = new Date(item.pubDate);
            dateStr = date.toLocaleDateString("en-US", {
              month: "short",
              day: "numeric",
              year: "numeric",
            });
          } catch (e) {
            dateStr = item.pubDate;
          }

          div.innerHTML = `
            <a href="${item.link}" target="_blank" rel="noopener noreferrer" class="group block space-y-1">
              <h4 class="font-sans text-xs font-medium text-zinc-800 hover:text-blue-600 dark:text-zinc-300 dark:hover:text-blue-400 group-hover:underline transition-colors leading-relaxed">
                ${item.title}
              </h4>
              <div class="flex items-center gap-2 text-[10px] text-zinc-400 dark:text-zinc-500 font-mono">
                <span>${dateStr}</span>
                <span>•</span>
                <span>Visa Alert Update</span>
              </div>
            </a>
          `;
          newsList.appendChild(div);
        });

        container.classList.remove("hidden");
      }

      function isRelevantToSelected(
        title: string,
        originCode: string,
        destCode: string,
      ): boolean {
        const titleLower = title.toLowerCase();
        const originCountry = countries.find((c) => c.code === originCode);
        const destCountry = countries.find((c) => c.code === destCode);
        if (!originCountry || !destCountry) return false;

        const originName = originCountry.name.split(" (")[0].toLowerCase();
        const destName = destCountry.name.split(" (")[0].toLowerCase();

        const originCodeLower = originCode.toLowerCase();
        const destCodeLower = destCode.toLowerCase();

        return (
          titleLower.includes(originName) ||
          titleLower.includes(originCodeLower) ||
          titleLower.includes(destName) ||
          titleLower.includes(destCodeLower)
        );
      }

      function isThirdCountryNews(
        title: string,
        originCode: string,
        destCode: string,
      ): boolean {
        const titleLower = title.toLowerCase();

        for (const country of countries) {
          if (country.code === originCode || country.code === destCode) {
            continue;
          }

          const plainName = country.name.split(" (")[0].toLowerCase();
          if (plainName.length <= 3) continue;

          const escapedName = plainName.replace(
            /[-\/\\^$*+?.()|[\]{}]/g,
            "\\$&",
          );
          const regex = new RegExp(`\\b${escapedName}\\b`, "i");
          if (regex.test(titleLower)) {
            return true;
          }
        }
        return false;
      }

      function filterRecentNews(
        items: any[],
        origin: string,
        destination: string,
      ): any[] {
        const now = new Date().getTime();
        const relevantKeywords = [
          "visa",
          "travel",
          "passport",
          "airport",
          "entry",
          "border",
          "rule",
          "policy",
          "transit",
          "immigration",
          "flight",
          "arrival",
          "tourist",
          "citizen",
          "admission",
          "eta",
          "electronic travel authorization",
        ];

        return items.filter((item) => {
          let isRecent = false;
          try {
            const pubTime = new Date(item.pubDate).getTime();
            const diffDays = (now - pubTime) / (1000 * 60 * 60 * 24);
            isRecent = diffDays >= 0 && diffDays <= 180;
          } catch (e) {
            // date parsing failed
          }

          if (!isRecent) return false;

          const titleLower = item.title.toLowerCase();
          const matchesKeyword = relevantKeywords.some((keyword) =>
            titleLower.includes(keyword),
          );

          if (!matchesKeyword) return false;

          // Strict relevance check
          if (!isRelevantToSelected(item.title, origin, destination)) {
            return false;
          }

          // Exclude third country news
          if (isThirdCountryNews(item.title, origin, destination)) {
            return false;
          }

          return true;
        });
      }

      function fetchNews(origin: string, destination: string) {
        const originCountry = countries.find((c) => c.code === origin);
        const destinationCountry = countries.find(
          (c) => c.code === destination,
        );
        if (!originCountry || !destinationCountry) return;

        const originName = originCountry.name.split(" (")[0];
        const destinationName = destinationCountry.name.split(" (")[0];

        const query = encodeURIComponent(
          `${originName} ${destinationName} visa travel rule changes`,
        );
        const rssUrl = encodeURIComponent(
          `https://news.google.com/rss/search?q=${query}&hl=en-US&gl=US&ceid=US:en`,
        );
        const url = `https://api.rss2json.com/v1/api.json?rss_url=${rssUrl}`;

        fetch(url)
          .then((res) => res.json())
          .then((data) => {
            if (data.status === "ok" && data.items && data.items.length > 0) {
              const filtered = filterRecentNews(
                data.items,
                origin,
                destination,
              );
              if (filtered.length > 0) {
                displayNews(filtered);
              } else {
                hideNewsSection();
              }
            } else {
              hideNewsSection();
            }
          })
          .catch((err) => {
            console.error("Failed to fetch news:", err);
            hideNewsSection();
          });
      }

      function highlightVisaSlab(statusType: string, maxStayDays: number) {
        let uiStatusType = statusType;

        const activeSlab = document.querySelector(
          `[data-status-type="${uiStatusType}"]`,
        ) as HTMLDivElement;
        if (activeSlab) {
          activeSlab.classList.remove("opacity-30", "scale-100");
          activeSlab.classList.add("opacity-100", "scale-[1.02]");

          const textLabel = activeSlab.querySelector(".status-label");
          if (textLabel) {
            textLabel.classList.remove("text-zinc-500", "dark:text-zinc-400");
          }

          const subLabel = activeSlab.querySelector(".status-desc");
          if (subLabel) {
            subLabel.classList.remove("text-zinc-500", "dark:text-zinc-500");
            subLabel.classList.add("text-zinc-800", "dark:text-zinc-200");
          }

          if (uiStatusType === "visa_free") {
            activeSlab.classList.add(
              "shadow-glow-emerald",
              "border-emerald-500/50",
            );
            if (textLabel)
              textLabel.classList.add(
                "text-emerald-800",
                "dark:text-emerald-300",
              );
          } else if (uiStatusType === "evisa") {
            activeSlab.classList.add("shadow-glow-blue", "border-blue-500/50");
            if (textLabel)
              textLabel.classList.add("text-blue-800", "dark:text-blue-300");
          } else if (uiStatusType === "visa_on_arrival") {
            activeSlab.classList.add(
              "shadow-glow-amber",
              "border-amber-500/50",
            );
            if (textLabel)
              textLabel.classList.add("text-amber-800", "dark:text-amber-300");
          } else if (uiStatusType === "visa_required") {
            activeSlab.classList.add("shadow-glow-rose", "border-rose-500/50");
            if (textLabel)
              textLabel.classList.add("text-rose-800", "dark:text-rose-300");
          }

          const stayBadge = activeSlab.querySelector(
            ".stay-badge",
          ) as HTMLDivElement;
          if (stayBadge && maxStayDays > 0) {
            stayBadge.classList.remove("hidden");
            stayBadge.textContent = `Max Allowed Stay: ${maxStayDays} Days`;

            if (uiStatusType === "visa_free") {
              stayBadge.className =
                "stay-badge mt-2 md:mt-0 ml-14 md:ml-0 text-[11px] font-mono px-3 py-1 rounded-full border bg-emerald-55/50 text-emerald-700 border-emerald-200/50 dark:bg-emerald-500/10 dark:text-emerald-400 dark:border-emerald-500/20 transition-colors";
            } else if (uiStatusType === "evisa") {
              stayBadge.className =
                "stay-badge mt-2 md:mt-0 ml-14 md:ml-0 text-[11px] font-mono px-3 py-1 rounded-full border bg-blue-55/50 text-blue-700 border-blue-200/50 dark:bg-blue-500/10 dark:text-blue-400 dark:border-blue-500/20 transition-colors";
            } else if (uiStatusType === "visa_on_arrival") {
              stayBadge.className =
                "stay-badge mt-2 md:mt-0 ml-14 md:ml-0 text-[11px] font-mono px-3 py-1 rounded-full border bg-amber-55/50 text-amber-700 border-amber-200/50 dark:bg-amber-500/10 dark:text-amber-400 dark:border-amber-500/20 transition-colors";
            }
          }
        }

        // Dynamically construct digital application portals matching specific eVisa destinations
        const origin = originInput.getAttribute("data-selected-code") || "";
        const destination =
          destinationInput.getAttribute("data-selected-code") || "";
        let portalUrl = "";

        if (uiStatusType === "evisa") {
          if (origin === "US" && destination === "IN")
            portalUrl = "https://indianvisaonline.gov.in/evisa/tvoa.html";
          else if (origin === "DE" && destination === "IN")
            portalUrl = "https://indianvisaonline.gov.in/evisa/tvoa.html";
          else if (origin === "SG" && destination === "IN")
            portalUrl = "https://indianvisaonline.gov.in/evisa/tvoa.html";
          else if (origin === "AE" && destination === "IN")
            portalUrl = "https://indianvisaonline.gov.in/evisa/tvoa.html";
          else if (origin === "DE" && destination === "US")
            portalUrl = "https://esta.cbp.dhs.gov/";
          else if (origin === "SG" && destination === "US")
            portalUrl = "https://esta.cbp.dhs.gov/";
          else if (origin === "IN" && destination === "SG")
            portalUrl =
              "https://www.ica.gov.sg/enter-transit-depart/entering-singapore/visa_requirements";
        }

        if (portalLinkContainer && portalLink) {
          if (portalUrl) {
            portalLink.href = portalUrl;
            portalLinkContainer.classList.remove("hidden");
            portalLinkContainer.classList.add("flex");
          } else {
            portalLinkContainer.classList.remove("flex");
            portalLinkContainer.classList.add("hidden");
          }
        }
      }

      function setupCombobox(
        input: HTMLInputElement,
        dropdown: HTMLDivElement,
      ) {
        function renderOptions(filterText = "") {
          dropdown.innerHTML = "";
          const filtered = countries.filter(
            (c) =>
              c.name.toLowerCase().includes(filterText.toLowerCase()) ||
              c.code.toLowerCase().includes(filterText.toLowerCase()),
          );

          if (filtered.length === 0) {
            const noMatch = document.createElement("div");
            noMatch.className = "px-4 py-3 text-xs text-zinc-500 italic";
            noMatch.textContent = "No matching countries";
            dropdown.appendChild(noMatch);
            return;
          }

          filtered.forEach((c) => {
            const option = document.createElement("div");
            option.className =
              "px-4 py-3 text-sm text-zinc-700 hover:bg-zinc-100 hover:text-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-900 dark:hover:text-white cursor-pointer transition-colors flex items-center gap-2";
            option.innerHTML = `<span>${c.flag}</span> <span>${c.name}</span>`;

            option.addEventListener("pointerdown", (e) => {
              e.preventDefault();
              selectOption(c);
            });
            dropdown.appendChild(option);
          });
        }

        function selectOption(country: {
          code: string;
          name: string;
          flag: string;
        }) {
          input.value = `${country.flag} ${country.name}`;
          input.setAttribute("data-selected-code", country.code);
          hideDropdown();
          checkStatus();

          // Auto-focus next input on mobile/tablet after origin country selection
          if (input === originInput && window.innerWidth < 1024) {
            destinationInput.focus();
          }
        }

        function showDropdown(delay = false) {
          if (delay && window.innerWidth < 1024) {
            setTimeout(() => {
              dropdown.classList.remove("hidden");
              renderOptions(input.value);
            }, 150);
          } else {
            dropdown.classList.remove("hidden");
            renderOptions(input.value);
          }
        }

        function hideDropdown() {
          dropdown.classList.add("hidden");
        }

        function resetInput(delay = false) {
          input.value = "";
          input.removeAttribute("data-selected-code");
          showDropdown(delay);
          checkStatus();
        }

        input.addEventListener("focus", () => resetInput(true));
        input.addEventListener("click", () => {
          if (input.value !== "") {
            resetInput(true);
          } else {
            showDropdown(true);
          }
        });
        input.addEventListener("input", () => showDropdown(false));

        input.addEventListener("blur", () => {
          const code = input.getAttribute("data-selected-code");
          const current = countries.find((c) => c.code === code);
          if (current) {
            input.value = `${current.flag} ${current.name}`;
          }
          setTimeout(hideDropdown, 150);
        });
      }

      function initializeApp() {
        if (countries.length > 0) {
          const originCode = originInput.getAttribute("data-selected-code");
          const destCode = destinationInput.getAttribute("data-selected-code");

          const originCountry = countries.find((c) => c.code === originCode);
          if (originCountry)
            originInput.value = `${originCountry.flag} ${originCountry.name}`;

          const destCountry = countries.find((c) => c.code === destCode);
          if (destCountry)
            destinationInput.value = `${destCountry.flag} ${destCountry.name}`;
        }

        setupCombobox(originInput, originDropdown);
        setupCombobox(destinationInput, destinationDropdown);
        checkStatus();
      }

      initializeApp();
    });
  </script>
</Layout>
