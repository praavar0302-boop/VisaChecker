---
import Layout from "../layouts/Layout.astro";
import visaDataMatrix from "../data/passport-index.json";
import Footer from "../components/Footer.astro";
import FrictionWarningBanner from "../components/FrictionWarningBanner.astro";
---

<Layout>
  <!-- Background Glow FX (Vercel atmospheric depth) -->
  <div
    class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-gradient-to-tr from-[#007cf0]/10 via-[#7928ca]/10 to-[#ff0080]/5 blur-[130px] pointer-events-none"
  >
  </div>
  <div
    class="absolute bottom-10 right-1/4 w-[500px] h-[500px] rounded-full bg-gradient-to-br from-[#00dfd8]/5 via-[#f9cb28]/5 to-emerald-500/5 blur-[120px] pointer-events-none"
  >
  </div>

  <!-- Header Nav -->
  <header
    class="sticky top-0 z-50 border-b border-zinc-200 bg-white/80 dark:border-zinc-900 dark:bg-black/80 backdrop-blur-md transition-colors duration-300"
  >
    <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img
          src="/favicon-96x96.png"
          alt="Logo"
          class="w-6 h-6 object-contain"
        />
        <span
          class="font-sans font-semibold tracking-tight text-zinc-950 dark:text-white text-base transition-colors"
          >Global Visa Tracker</span
        >
      </div>

      <div class="flex items-center gap-6">
        <nav
          class="hidden md:flex items-center gap-6 text-xs font-mono text-zinc-500 dark:text-zinc-400"
        >
          <a
            href="/"
            class="text-zinc-950 dark:text-white font-semibold transition-colors"
            >Home</a
          >
          <a
            href="/methodology"
            class="hover:text-zinc-950 dark:hover:text-white transition-colors"
            >Methodology</a
          >
          <a
            href="/about"
            class="hover:text-zinc-950 dark:hover:text-white transition-colors"
            >About</a
          >
          <a
            href="/privacy"
            class="hover:text-zinc-950 dark:hover:text-white transition-colors"
            >Privacy</a
          >
          <a
            href="/terms"
            class="hover:text-zinc-950 dark:hover:text-white transition-colors"
            >Terms</a
          >
          <a
            href="/contact"
            class="hover:text-zinc-950 dark:hover:text-white transition-colors"
            >Contact</a
          >
        </nav>
        <div class="flex items-center gap-4">
          <!-- Theme Toggle Button -->
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle dark/light mode"
            class="flex items-center justify-center w-8 h-8 rounded-full border border-zinc-200 bg-white text-zinc-700 hover:bg-zinc-100 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-900 transition-colors cursor-pointer"
          >
            <!-- Sun Icon (visible in dark mode) -->
            <svg
              class="w-4 h-4 hidden dark:block"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m12.728 12.728l.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"
              ></path>
            </svg>
            <!-- Moon Icon (visible in light mode) -->
            <svg
              class="w-4 h-4 block dark:hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
              ></path>
            </svg>
          </button>

          <span
            class="hidden sm:inline-block font-mono text-[10px] text-zinc-500 dark:text-zinc-400 uppercase tracking-widest bg-zinc-100 border border-zinc-200 dark:bg-zinc-900 dark:border-zinc-800 px-2 py-1 rounded transition-colors"
          >
            v2.0.1 Stable
          </span>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Hero Section -->
  <main class="max-w-5xl mx-auto px-4 pt-12 pb-24 relative">
    <!-- Title Area -->
    <div class="text-center md:text-left mb-10">
      <div
        class="inline-block mb-3 px-3 py-1 rounded-full border border-zinc-200 bg-zinc-100/60 dark:border-zinc-800 dark:bg-zinc-900/60 font-mono text-xs text-zinc-600 dark:text-zinc-400 transition-colors"
      >
        Instant VISA Search Engine
      </div>
      <h1
        class="font-sans text-4xl md:text-5xl font-semibold tracking-tight text-zinc-950 dark:text-white mb-4 transition-colors"
      >
        Can I Fly There? Instant Visa Requirement Checker
      </h1>
      <p
        class="font-sans text-zinc-600 dark:text-zinc-400 text-lg max-w-2xl leading-relaxed transition-colors"
      >
        Select your origin and destination countries to check the current VISA
        requirements in real-time.
      </p>

      <!-- Quick Navigation Links in Hero -->
      <div
        class="mt-6 flex flex-wrap justify-center md:justify-start gap-x-6 gap-y-2 text-xs font-mono text-zinc-500 dark:text-zinc-400"
      >
        <a
          href="/about"
          class="hover:text-zinc-950 dark:hover:text-white transition-colors border-b border-zinc-200 dark:border-zinc-800 pb-0.5"
          >About Us</a
        >
        <a
          href="/privacy"
          class="hover:text-zinc-950 dark:hover:text-white transition-colors border-b border-zinc-200 dark:border-zinc-800 pb-0.5"
          >Privacy Policy</a
        >
        <a
          href="/terms"
          class="hover:text-zinc-950 dark:hover:text-white transition-colors border-b border-zinc-200 dark:border-zinc-800 pb-0.5"
          >Terms & Conditions</a
        >
        <a
          href="/contact"
          class="hover:text-zinc-950 dark:hover:text-white transition-colors border-b border-zinc-200 dark:border-zinc-800 pb-0.5"
          >Contact Us</a
        >
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <!-- Left side: Select Panel -->
      <section class="lg:col-span-5 space-y-6">
        <div
          class="p-6 rounded-lg border border-zinc-200 bg-white dark:border-zinc-900 dark:bg-[#080808] shadow-[0_1px_2px_rgba(0,0,0,0.05)] dark:shadow-[0_1px_2px_rgba(0,0,0,0.4)] transition-colors"
        >
          <h2
            class="font-sans text-lg font-medium text-zinc-950 dark:text-white mb-6 flex items-center gap-2 transition-colors"
          >
            <svg
              class="w-4 h-4 text-zinc-500 dark:text-zinc-400 transition-colors"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            Enter your country
          </h2>

          <form class="space-y-5" onsubmit="return false;">
            <!-- Warning Message -->
            <div
              id="same-country-warning"
              class="hidden p-3 rounded-lg border border-amber-200/50 bg-amber-50/50 text-amber-800 dark:border-amber-900/30 dark:bg-amber-950/10 dark:text-amber-400 text-xs flex items-center gap-2 transition-colors"
            >
              <svg
                class="w-4 h-4 flex-shrink-0"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                ></path>
              </svg>
              <span>Origin and Destination countries cannot be the same.</span>
            </div>

            <!-- Origin Combobox -->
            <div class="space-y-2 relative">
              <label
                for="origin-input"
                class="block font-mono text-[10px] text-zinc-600 dark:text-zinc-300 uppercase tracking-wider transition-colors"
              >
                Origin Nationality (Passport)
              </label>
              <div class="relative">
                <input
                  type="text"
                  id="origin-input"
                  placeholder="Type origin passport country..."
                  class="w-full bg-zinc-100 text-zinc-950 border border-zinc-300 rounded px-3 py-3 font-sans text-sm focus:outline-none focus:border-zinc-500 dark:bg-zinc-900 dark:text-white dark:border-zinc-700 dark:focus:border-zinc-400 transition-colors cursor-text placeholder:text-zinc-500 dark:placeholder:text-zinc-400 placeholder:text-xs"
                  autocomplete="off"
                />
                <div
                  class="absolute inset-y-0 right-0 flex items-center px-3 text-zinc-450 dark:text-zinc-400 transition-colors pointer-events-none"
                >
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </div>
              <!-- Dropdown Options List -->
              <div
                id="origin-dropdown"
                class="absolute z-20 w-full mt-1 max-h-60 overflow-y-auto rounded-md border border-zinc-300 bg-white dark:border-zinc-700 dark:bg-zinc-900 hidden shadow-lg dark:shadow-[0_10px_20px_-10px_rgba(0,0,0,0.7)] divide-y divide-zinc-100 dark:divide-zinc-800 transition-colors"
              >
              </div>
            </div>

            <!-- Swap Button Centered -->
            <div class="flex justify-center py-1">
              <button
                type="button"
                id="swap-countries-btn"
                aria-label="Swap origin and destination countries"
                class="w-9 h-9 rounded-full border border-zinc-200 bg-white text-zinc-500 hover:text-zinc-950 hover:border-zinc-400 hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-400 dark:hover:text-white dark:hover:border-zinc-600 dark:hover:bg-zinc-900 flex items-center justify-center transition-all cursor-pointer hover:scale-105 active:scale-95 shadow-[0_1px_2px_rgba(0,0,0,0.05)] dark:shadow-none"
              >
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 20V4M5 8l4-4 4 4M15 4v16M11 16l4 4 4-4"></path>
                </svg>
              </button>
            </div>

            <!-- Destination Combobox -->
            <div class="space-y-2 relative">
              <label
                for="destination-input"
                class="block font-mono text-[10px] text-zinc-600 dark:text-zinc-300 uppercase tracking-wider transition-colors"
              >
                Destination Country
              </label>
              <div class="relative">
                <input
                  type="text"
                  id="destination-input"
                  placeholder="Type destination country..."
                  class="w-full bg-zinc-100 text-zinc-950 border border-zinc-300 rounded px-3 py-3 font-sans text-sm focus:outline-none focus:border-zinc-500 dark:bg-zinc-900 dark:text-white dark:border-zinc-700 dark:focus:border-zinc-400 transition-colors cursor-text placeholder:text-zinc-500 dark:placeholder:text-zinc-400 placeholder:text-xs"
                  autocomplete="off"
                />
                <div
                  class="absolute inset-y-0 right-0 flex items-center px-3 text-zinc-450 dark:text-zinc-400 transition-colors pointer-events-none"
                >
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19 9l-7 7-7-7"></path>
                  </svg>
                </div>
              </div>
              <!-- Dropdown Options List -->
              <div
                id="destination-dropdown"
                class="absolute z-20 w-full mt-1 max-h-60 overflow-y-auto rounded-md border border-zinc-300 bg-white dark:border-zinc-700 dark:bg-zinc-900 hidden shadow-lg dark:shadow-[0_10px_20px_-10px_rgba(0,0,0,0.7)] divide-y divide-zinc-100 dark:divide-zinc-800 transition-colors"
              >
              </div>
            </div>
          </form>
        </div>

        <!-- Optional Direct Portal Apply Alert Box -->
        <div
          id="portal-link-container"
          class="hidden p-5 rounded-lg border border-blue-200/50 bg-blue-50/50 text-zinc-800 dark:border-blue-900/30 dark:bg-blue-950/10 dark:text-zinc-300 text-sm flex-col gap-3 transition-colors"
        >
          <div
            class="flex items-center gap-2 text-blue-600 dark:text-blue-400 font-medium transition-colors"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
              ></path>
            </svg>
            <span>Digital Application Portal Found</span>
          </div>
          <p
            class="text-zinc-600 dark:text-zinc-400 leading-relaxed text-xs transition-colors"
          >
            This destination supports an online electronic application process.
            You can apply directly through the authorized government portal.
          </p>
          <a
            id="portal-link"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-full bg-zinc-900 border border-zinc-800 hover:bg-zinc-800 hover:border-zinc-700 text-white dark:bg-zinc-900 dark:border-zinc-800 dark:hover:bg-zinc-800 dark:hover:border-zinc-700 font-sans text-xs py-2 px-3 rounded mt-1 transition-colors"
          >
            Access Application Portal
          </a>
        </div>
      </section>

      <!-- Right side: Matrix Output & PDF Viewer -->
      <section id="results-section" class="lg:col-span-7 space-y-8">
        <!-- Matrix Slabs -->
        <div
          id="results-container"
          class="p-6 rounded-lg border border-zinc-200 bg-white dark:border-zinc-900 dark:bg-[#080808] space-y-4 transition-colors"
        >
          <div class="flex justify-between items-center mb-2">
            <h2
              class="font-sans text-lg font-medium text-zinc-950 dark:text-white transition-colors"
            >
              Visa Requirements
            </h2>
            <span class="font-mono text-[10px] text-zinc-500">
              Search Results
            </span>
          </div>

          <div class="space-y-3" aria-live="polite">
            <!-- Slab 1: Visa-Free (Emerald) -->
            <div
              data-status-type="visa_free"
              class="relative flex flex-col md:flex-row items-start md:items-center justify-between p-5 rounded-lg border bg-zinc-50/50 border-zinc-200 dark:bg-gray-950/40 dark:border-gray-800 opacity-30 transition-all duration-300 scale-100 ease-out"
            >
              <div class="flex items-center gap-4">
                <div
                  class="flex-shrink-0 w-10 h-10 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-600 dark:text-emerald-400"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div
                    class="status-label font-sans font-semibold text-zinc-400 transition-colors duration-300"
                  >
                    Visa-Free Travel
                  </div>
                  <div
                    class="status-desc text-[11px] text-zinc-500 mt-0.5 transition-colors duration-300"
                  >
                    Unrestricted bilateral transit access
                  </div>
                </div>
              </div>
              <!-- Hidden placeholder for stay duration -->
              <div class="stay-badge hidden mt-2 md:mt-0"></div>
            </div>

            <!-- Slab 2: e-Visa (Blue) -->
            <div
              data-status-type="evisa"
              class="relative flex flex-col md:flex-row items-start md:items-center justify-between p-5 rounded-lg border bg-zinc-50/50 border-zinc-200 dark:bg-gray-950/40 dark:border-gray-800 opacity-30 transition-all duration-300 scale-100 ease-out"
            >
              <div class="flex items-center gap-4">
                <div
                  class="flex-shrink-0 w-10 h-10 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-600 dark:text-blue-400"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div
                    class="status-label font-sans font-semibold text-zinc-400 transition-colors duration-300"
                  >
                    e-Visa / Electronic Authorization
                  </div>
                  <div
                    class="status-desc text-[11px] text-zinc-500 mt-0.5 transition-colors duration-300"
                  >
                    Pre-departure registration portal required
                  </div>
                </div>
              </div>
              <!-- Hidden placeholder for stay duration -->
              <div class="stay-badge hidden mt-2 md:mt-0"></div>
            </div>

            <!-- Slab 3: Visa on Arrival (Amber) -->
            <div
              data-status-type="visa_on_arrival"
              class="relative flex flex-col md:flex-row items-start md:items-center justify-between p-5 rounded-lg border bg-zinc-50/50 border-zinc-200 dark:bg-gray-950/40 dark:border-gray-800 opacity-30 transition-all duration-300 scale-100 ease-out"
            >
              <div class="flex items-center gap-4">
                <div
                  class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-600 dark:text-amber-400"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <div>
                  <div
                    class="status-label font-sans font-semibold text-zinc-400 transition-colors duration-300"
                  >
                    Visa on Arrival
                  </div>
                  <div
                    class="status-desc text-[11px] text-zinc-500 mt-0.5 transition-colors duration-300"
                  >
                    Acquired at destination border terminal checkpoint
                  </div>
                </div>
              </div>
              <!-- Hidden placeholder for stay duration -->
              <div class="stay-badge hidden mt-2 md:mt-0"></div>
            </div>

            <!-- Slab 4: Embassy Visa (Rose) -->
            <div
              data-status-type="visa_required"
              class="relative flex flex-col md:flex-row items-start md:items-center justify-between p-5 rounded-lg border bg-zinc-50/50 border-zinc-200 dark:bg-gray-950/40 dark:border-gray-800 opacity-30 transition-all duration-300 scale-100 ease-out"
            >
              <div class="flex items-center gap-4">
                <div
                  class="flex-shrink-0 w-10 h-10 rounded-full bg-rose-500/10 border border-rose-500/20 flex items-center justify-center text-rose-600 dark:text-rose-450"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                    ></path>
                  </svg>
                </div>
                <div>
                  <div
                    class="status-label font-sans font-semibold text-zinc-400 transition-colors duration-300"
                  >
                    Embassy Visa Required
                  </div>
                  <div
                    class="status-desc text-[11px] text-zinc-500 mt-0.5 transition-colors duration-300"
                  >
                    Physical consul interview or agency filing compulsory
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Friction Warning Banner Wrapper -->
          <div id="compliance-banner-container" class="hidden mt-4">
            <FrictionWarningBanner />
          </div>

          <!-- Detail on Demand Verification Layer -->
          <div
            id="detail-on-demand-container"
            class="hidden pt-4 border-t border-zinc-200 dark:border-zinc-800 mt-4 flex flex-col gap-3 transition-all duration-300"
          >
            <!-- Minimalist Default State Row -->
            <div class="flex items-center justify-between w-full text-xs">
              <div class="flex items-center gap-1.5 font-mono text-[10px] text-zinc-400 dark:text-zinc-500">
                <span>Last verified:</span>
                <span id="details-date" class="font-medium text-zinc-500 dark:text-zinc-400">Today</span>
                <span>•</span>
                <span>Source: PassportIndex Daily Sync</span>
              </div>
              <button
                id="details-toggle-btn"
                type="button"
                class="flex items-center gap-1 font-mono text-[11px] text-zinc-500 hover:text-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors cursor-pointer select-none focus:outline-none"
                aria-expanded="false"
                aria-controls="details-panel"
              >
                <span>Click to expand details</span>
                <svg
                  id="details-chevron"
                  class="w-3.5 h-3.5 transition-transform duration-300 transform"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            </div>

            <!-- Expandable Disclosure Panel -->
            <div
              id="details-panel"
              class="max-h-0 opacity-0 overflow-hidden transition-all duration-300 ease-in-out"
            >
              <div class="space-y-3 pt-2">
                <!-- Disclaimer Box -->
                <div class="flex items-start gap-2.5 p-3 rounded-lg border border-zinc-200 bg-zinc-50/50 text-zinc-500 dark:border-zinc-800/80 dark:bg-zinc-950/20 dark:text-zinc-400 text-[11px] leading-relaxed transition-colors">
                  <svg
                    class="w-4 h-4 text-zinc-400 dark:text-zinc-500 flex-shrink-0 mt-0.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
