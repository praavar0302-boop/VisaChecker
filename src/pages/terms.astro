---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <!-- Background Glow FX -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-gradient-to-tr from-[#007cf0]/10 via-[#7928ca]/10 to-[#ff0080]/5 blur-[130px] pointer-events-none"></div>
  <div class="absolute bottom-10 right-1/4 w-[500px] h-[500px] rounded-full bg-gradient-to-br from-[#00dfd8]/5 via-[#f9cb28]/5 to-emerald-500/5 blur-[120px] pointer-events-none"></div>

  <!-- Content Section -->
  <main class="max-w-3xl mx-auto px-4 py-16 relative">
    <article class="space-y-8 text-zinc-600 dark:text-zinc-400">
      <div class="space-y-4">
        <span class="font-mono text-[10px] text-zinc-500 uppercase tracking-widest block">
          Terms & Conditions
        </span>
        <h1 class="font-sans text-3xl font-semibold text-zinc-950 dark:text-white tracking-tight transition-colors">
          Terms of Use & Disclaimer
        </h1>
        <p class="font-sans text-sm leading-relaxed">
          Welcome to Global Visa Tracker. By using this tool, you agree to these Terms. If you do not agree, please do not use our services.
        </p>
      </div>

      <hr class="border-zinc-200 dark:border-zinc-900" />

      <div class="space-y-4">
        <h2 class="font-sans text-lg font-medium text-zinc-950 dark:text-white transition-colors">
          Bilateral Data Matrix Disclaimer
        </h2>
        <p class="font-sans text-sm leading-relaxed">
          The information contained in this visa database matrix is compiled for reference and general educational purposes only. Visa requirements, stays, and electronic portals can change rapidly without notice. It is the sole responsibility of the traveler to cross-reference and verify official guidelines directly with the destination country's government portal or authorized consulate before booking flights or starting journeys.
        </p>
        <p class="font-sans text-sm leading-relaxed">
          We assume no liability or responsibility for border denials, delayed flights, or administrative issues resulting from the use of this lookup system.
        </p>
      </div>
    </article>
  </main>

  <!-- Reusable Footer -->
  <Footer />


</Layout>
