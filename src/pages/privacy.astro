---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <!-- Background Glow FX -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] rounded-full bg-gradient-to-tr from-[#007cf0]/10 via-[#7928ca]/10 to-[#ff0080]/5 blur-[130px] pointer-events-none"></div>
  <div class="absolute bottom-10 right-1/4 w-[500px] h-[500px] rounded-full bg-gradient-to-br from-[#00dfd8]/5 via-[#f9cb28]/5 to-emerald-500/5 blur-[120px] pointer-events-none"></div>

  <!-- Content Section -->
  <main class="max-w-3xl mx-auto px-4 py-16 relative">
    <article class="space-y-8 text-zinc-600 dark:text-zinc-400">
      <div class="space-y-4">
        <span class="font-mono text-[10px] text-zinc-500 uppercase tracking-widest block">
          Privacy Policy
        </span>
        <h1 class="font-sans text-3xl font-semibold text-zinc-950 dark:text-white tracking-tight transition-colors">
          Privacy Policy & Data Caching Guidelines
        </h1>
        <p class="font-sans text-sm leading-relaxed">
          At Global Visa Tracker, we prioritize the privacy and security of our users. We build services that respect travel search data. This Policy outlines how our application interacts with local states, parameters, and cookies.
        </p>
      </div>

      <hr class="border-zinc-200 dark:border-zinc-900" />

      <div class="space-y-4">
        <h2 class="font-sans text-lg font-medium text-zinc-950 dark:text-white transition-colors">
          Zero Tracking & User Preferences
        </h2>
        <p class="font-sans text-sm leading-relaxed">
          We do not store, compile, or transmit your search inputs, passport selections, or location queries to any external database or analytics provider. All searchable country selection parameters and theme options (dark/light toggles) are stored locally on your device within your browser's native <strong>localStorage</strong>.
        </p>
        <p class="font-sans text-sm leading-relaxed">
          You may clear your browser's cache or local storage at any time to remove these details.
        </p>
      </div>
    </article>
  </main>

  <!-- Reusable Footer -->
  <Footer />


</Layout>
